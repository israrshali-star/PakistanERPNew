{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PakistanAccountingERP;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedOnStartup": true
  },
  "AppSettings": {
    "ApplicationName": "Pakistan Accounting ERP",
    "Version": "1.0.0",
    "DefaultCurrency": "PKR",
    "DateFormat": "yyyy/MM/dd",
    "SessionTimeoutMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
