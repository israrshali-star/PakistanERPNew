@{
    ViewData["Title"] = "Roles & Permissions";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Roles & Permissions</h4>
        <p class="text-muted small mb-0">Manage role-based access matrix for all modules</p>
    </div>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table table-hover w-100" id="roles-table">
            <thead>
                <tr>
                    <th>Role</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/roles.js" asp-append-version="true"></script>
}
