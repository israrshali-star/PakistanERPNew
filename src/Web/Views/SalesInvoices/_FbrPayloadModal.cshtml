<div class="modal fade" id="fbrPayloadModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary">FBR Submission Preview (JSON)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small" id="fbr-payload-hint"></p>
                <pre class="bg-light border rounded p-3 small mb-0" id="fbr-payload-json" style="max-height: 55vh; overflow: auto;"></pre>
                <div class="alert alert-danger d-none mt-3" id="fbr-payload-error"></div>
                <p class="text-muted small mt-3 mb-0">
                    Seller and buyer details are taken from company settings and invoice customer. Review the JSON before submitting.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btn-confirm-fbr-submit">
                    <i class="fa-solid fa-paper-plane me-1"></i>Submit to FBR
                </button>
            </div>
        </div>
    </div>
</div>
