@using PakistanAccountingERP.Application.Common
@using PakistanAccountingERP.Application.DTOs
@using PakistanAccountingERP.Application.Interfaces.Services
@using PakistanAccountingERP.Domain.Enums
@inject IPermissionService PermissionService
@model SalesInvoiceDetailDto
@{
    ViewData["Title"] = "Invoice " + Model.InvoiceNumber;
    var canEdit = await PermissionService.HasPermissionAsync("Sales.Edit");
    var canPost = canEdit && Model.Status == InvoiceStatus.Draft;
    var canCancel = canEdit && Model.Status == InvoiceStatus.Draft;
    var canSubmitFbr = canEdit && Model.Status == InvoiceStatus.Posted && Model.FbrSubmittedAt is null;
    var canRecreate = await PermissionService.HasPermissionAsync("Sales.Create")
        && Model.Status != InvoiceStatus.Draft;
    var canDelete = await PermissionService.HasPermissionAsync("Sales.Delete")
        && Model.FbrSubmittedAt is null;
    var useTradeInvoice = Model.CompanyId == TradeInvoiceLayout.TradeInvoiceCompanyId;
    var canDownloadPdf = Model.CanDownloadInvoicePdf;
    var exclusiveTotal = Model.SubTotal - Model.DiscountAmount;
    var taxPeriod = FbrInvoiceLayout.FormatTaxPeriod(Model.InvoiceDate);
    var invoiceTypeLabel = FbrInvoiceLayout.MapInvoiceTypeLabel(Model.InvoiceType);
    var saleType = FbrPayloadBuilder.MapSaleType(Model.ScenarioCode);
    var fbrDisplayNumber = Model.FbrInvoiceNumber ?? Model.InvoiceNumber;
    var sellerNtnCnic = FbrInvoiceLayout.ResolveNtnCnic(Model.SellerNtn, null);
    var buyerNtnCnic = FbrInvoiceLayout.ResolveNtnCnic(Model.BuyerNTN, Model.BuyerCNIC);
    const string ScreenFooterNotice = FbrInvoiceLayout.ScreenFooterNotice;
}

<div id="invoice-detail"
     data-id="@Model.Id"
     data-can-post="@canPost.ToString().ToLower()"
     data-can-cancel="@canCancel.ToString().ToLower()"
     data-can-submit-fbr="@canSubmitFbr.ToString().ToLower()"
     data-can-delete="@canDelete.ToString().ToLower()"
     data-can-download-pdf="@canDownloadPdf.ToString().ToLower()"
     data-can-share="@canDownloadPdf.ToString().ToLower()"></div>

<div id="invoice-action-message" class="alert d-none mb-3 no-print"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-0">@Model.InvoiceNumber</h4>
        <p class="text-muted small mb-0">@Model.CustomerCode — @Model.CustomerName · @Model.Status</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to list
        </a>
        <a asp-controller="Customers" asp-action="Ledger" asp-route-id="@Model.CustomerId" class="btn btn-outline-primary btn-sm">
            <i class="fa-solid fa-book me-1"></i>Customer Ledger
        </a>
        @if (canPost)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-pen me-1"></i>Edit Draft
            </a>
            <button type="button" class="btn btn-success btn-sm" id="btn-post-invoice">
                <i class="fa-solid fa-book me-1"></i>Post to GL
            </button>
        }
        @if (canSubmitFbr)
        {
            <button type="button" class="btn btn-primary btn-sm" id="btn-submit-fbr">
                <i class="fa-solid fa-code me-1"></i>Preview & Submit FBR
            </button>
        }
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btn-download-challan" title="Delivery challan PDF for goods dispatch">
            <i class="fa-solid fa-truck me-1"></i>Delivery Challan PDF
        </button>
        @if (Model.Status == InvoiceStatus.Posted && Model.CompanyId == TradeInvoiceLayout.TradeInvoiceCompanyId)
        {
            <button type="button" class="btn btn-outline-warning btn-sm" id="btn-email-challan-godown" title="Email delivery challan to godown">
                <i class="fa-solid fa-envelope me-1"></i>Email Challan to Godown
            </button>
        }
        @if (canDownloadPdf)
        {
            <button type="button" class="btn btn-outline-danger btn-sm" id="btn-download-pdf" title="Download PDF invoice">
                <i class="fa-solid fa-file-pdf me-1"></i>Download PDF
            </button>
            <button type="button" class="btn btn-outline-success btn-sm" id="btn-share-invoice" title="Email or WhatsApp invoice to customer">
                <i class="fa-solid fa-share-nodes me-1"></i>Share
            </button>
        }
        @if (canCancel)
        {
            <button type="button" class="btn btn-outline-danger btn-sm" id="btn-cancel-invoice">
                <i class="fa-solid fa-ban me-1"></i>Cancel Draft
            </button>
        }
        @if (canRecreate)
        {
            <a asp-action="Copy" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-copy me-1"></i>Recreate Invoice
            </a>
        }
        @if (canDelete)
        {
            <button type="button" class="btn btn-danger btn-sm" id="btn-delete-invoice">
                <i class="fa-solid fa-trash me-1"></i>Delete Invoice
            </button>
        }
        <button type="button" class="btn btn-outline-primary btn-sm" onclick="window.print()">
            <i class="fa-solid fa-print me-1"></i>Print
        </button>
    </div>
</div>

@if (useTradeInvoice)
{
    <partial name="_TradeInvoiceDocument" model="Model" />
}
else
{
<div class="fbr-invoice-doc" id="fbr-invoice-document">
    <div class="row align-items-start g-2 mb-3">
        <div class="col-auto">
            <div class="fbr-header-logo">
                <div class="fw-bold fbr-green">FBR</div>
                <div class="small">DIGITAL</div>
                <div class="small">INVOICING</div>
                <div class="small">SYSTEM</div>
            </div>
        </div>
        <div class="col text-center">
            <div class="fw-bold fs-5">@(Model.SellerCompanyName ?? "—")</div>
            <div class="fbr-title">SALES TAX INVOICE</div>
            <div class="fbr-number-bar mt-2">FBR DIGITAL INVOICE #@fbrDisplayNumber</div>
        </div>
        <div class="col-auto">
            <div class="fbr-qr-placeholder">QR Code<br />(on PDF)</div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <div class="fbr-party-box">
                <div class="fw-bold fbr-green mb-2">Seller Information</div>
                <div><span class="fw-semibold">Name:</span> @(Model.SellerCompanyName ?? "—")</div>
                <div><span class="fw-semibold">Address:</span> @(Model.SellerAddress ?? "—")@(string.IsNullOrWhiteSpace(Model.SellerProvince) ? "" : ", " + Model.SellerProvince)</div>
                <div><span class="fw-semibold">NTN / CNIC:</span> @sellerNtnCnic</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="fbr-party-box">
                <div class="fw-bold fbr-green mb-2">Buyer Information</div>
                <div><span class="fw-semibold">Name:</span> @Model.CustomerName</div>
                <div><span class="fw-semibold">Address:</span> @(Model.BuyerAddress ?? "—")</div>
                <div><span class="fw-semibold">Shipping Address:</span> @(Model.ShippingAddress ?? "—")</div>
                @if (!string.IsNullOrWhiteSpace(Model.BuyerProvince))
                {
                    <div><span class="fw-semibold">Province:</span> @Model.BuyerProvince.ToUpperInvariant()</div>
                }
                <div><span class="fw-semibold">NTN / CNIC:</span> @buyerNtnCnic</div>
            </div>
        </div>
    </div>

    <div class="fbr-meta-bar row g-2 mb-3">
        <div class="col-md-3">
            <div class="fbr-meta-label">Invoice date</div>
            <div>@Model.InvoiceDate.ToString("dd/MM/yyyy")</div>
        </div>
        <div class="col-md-3">
            <div class="fbr-meta-label">Invoice type</div>
            <div>@invoiceTypeLabel</div>
        </div>
        <div class="col-md-3">
            <div class="fbr-meta-label">Tax period</div>
            <div>@taxPeriod</div>
        </div>
        <div class="col-md-3">
            <div class="fbr-meta-label">Reference no.</div>
            <div>@Model.InvoiceNumber</div>
        </div>
    </div>

    <div class="table-responsive mb-3">
        <table class="table table-sm table-bordered fbr-table mb-0">
            <thead>
                <tr>
                    <th>Sr</th>
                    <th>Product</th>
                    <th>HS code</th>
                    <th>Sale type</th>
                    <th class="text-end">Qty</th>
                    <th>UoM</th>
                    <th class="text-end">Tax %</th>
                    <th class="text-end">Val ex ST</th>
                    <th class="text-end">Sales ST</th>
                    <th class="text-end">F. tax</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                @{ var sr = 0; }
                @foreach (var line in Model.Lines)
                {
                    sr++;
                    var valueExSt = Math.Max(0m, line.Quantity * line.Price - line.Discount);
                    var product = FbrInvoiceLayout.BuildFbrProductDescription(line.ItemDescription, line.LotNo, line.StackNo);
                    <tr>
                        <td>@sr</td>
                        <td>@product</td>
                        <td>@(line.HsCode ?? "—")</td>
                        <td>@saleType</td>
                        <td class="text-end">@line.Quantity.ToString("N2")</td>
                        <td>@(line.Unit ?? "—")</td>
                        <td class="text-end">@FbrInvoiceLayout.FormatTaxRate(line.TaxRate)</td>
                        <td class="text-end">@valueExSt.ToString("N2")</td>
                        <td class="text-end">@line.TaxAmount.ToString("N2")</td>
                        <td class="text-end">0.00</td>
                        <td class="text-end fw-semibold">@line.LineTotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="fbr-summary mb-3">
        <div class="d-flex justify-content-between mb-1">
            <span class="fw-semibold">Exclusive total amount</span>
            <span>@exclusiveTotal.ToString("N2")</span>
        </div>
        <div class="d-flex justify-content-between mb-2">
            <span class="fw-semibold">Sales tax</span>
            <span>@Model.TaxAmount.ToString("N2")</span>
        </div>
        <div class="d-flex justify-content-between border-top pt-2">
            <span class="fw-bold">Inclusive total amount</span>
            <span class="fbr-inclusive-total">@Model.NetTotal.ToString("N2")</span>
        </div>
    </div>

    <div class="mb-3"><span class="fw-semibold">Amount in words::</span> @AmountInWords.ToPakistaniRupees(Model.NetTotal)</div>

    
    <div class="text-center text-muted small"><strong>@ScreenFooterNotice</strong></div>
     
        
     
    </div>
}



<div class="card p-3 mb-3 no-print" id="invoice-attachments-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h6 class="text-primary mb-0">Supporting Documents</h6>
            <p class="text-muted small mb-0">JPG, PNG, and PDF attachments</p>
        </div>
        @if (canEdit && Model.Status == InvoiceStatus.Draft)
        {
            <label class="btn btn-outline-primary btn-sm mb-0" for="invoice-attachment-upload">
                <i class="fa-solid fa-paperclip me-1"></i>Add Attachment
            </label>
            <input type="file" class="d-none" id="invoice-attachment-upload" accept=".jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf" multiple />
        }
    </div>
    <div id="invoice-attachments-list">
        @if (Model.Attachments.Count == 0)
        {
            <p class="text-muted small mb-0">No attachments uploaded.</p>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var attachment in Model.Attachments)
                {
                    <div class="list-group-item d-flex flex-wrap justify-content-between align-items-center gap-2 px-0 attachment-row" data-id="@attachment.Id">
                        <div>
                            <a href="/api/sales-invoices/attachments/@attachment.Id/download" class="fw-semibold text-decoration-none" target="_blank" rel="noopener">
                                <i class="fa-solid fa-file me-1"></i>@attachment.FileName
                            </a>
                            <div class="text-muted small">@((attachment.FileSizeBytes / 1024.0).ToString("N1")) KB · @attachment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        @if (canEdit && Model.Status == InvoiceStatus.Draft)
                        {
                            <button type="button" class="btn btn-link btn-sm text-danger p-0 btn-delete-attachment" data-id="@attachment.Id">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<partial name="_FbrPayloadModal" />
<partial name="_InvoiceShareModal" />

@section Styles {
    @if (useTradeInvoice)
    {
        <link rel="stylesheet" href="~/css/trade-invoice.css" asp-append-version="true" />
    }
    else
    {
        <link rel="stylesheet" href="~/css/fbr-invoice.css" asp-append-version="true" />
    }
}

@section Scripts {
    <script src="~/js/modules/sales-invoice-fbr.js" asp-append-version="true"></script>
    <script src="~/js/modules/sales-invoice-share.js" asp-append-version="true"></script>
    <script src="~/js/modules/sales-invoice-details.js" asp-append-version="true"></script>
}
