@using System.Text.Json
@using PakistanAccountingERP.Application.Common
@using PakistanAccountingERP.Application.DTOs
@model SalesInvoiceDetailDto?
@{
    var isCopy = ViewData["IsCopy"] as bool? == true;
    var isEdit = Model != null && !isCopy;
    ViewData["Title"] = isEdit ? "Edit Sales Invoice" : (isCopy ? "Recreate Sales Invoice" : "Create Sales Invoice");
    var invoiceJson = (isEdit || isCopy) && Model != null
        ? JsonSerializer.Serialize(Model, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase })
        : null;
    var copyFromNumber = ViewData["CopyFromNumber"] as string;
}

<div id="invoice-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">@(isEdit ? "Edit Sales Invoice" : (isCopy ? "Recreate Sales Invoice" : "Create Sales Invoice"))</h4>
        <p class="text-muted small mb-0">@(isEdit ? "Update this draft before posting to GL" : (isCopy ? "New draft copied from " + copyFromNumber + " — review lines and save" : "Draft invoice with customer, FBR scenario, and line items"))</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Sales List
    </a>
</div>

@if (isCopy)
{
    <div class="alert alert-info py-2 small mb-2">
        <i class="fa-solid fa-copy me-1"></i>
        Recreating invoice from <strong>@copyFromNumber</strong>. A new invoice number will be assigned when you save.
    </div>
}

@if (isEdit || isCopy)
{
    <script type="application/json" id="invoice-edit-data">@Html.Raw(invoiceJson)</script>
}

<form id="sales-invoice-form" class="invoice-create-compact"
      data-edit-id="@(isEdit ? Model!.Id : "")"
      data-copy-mode="@(isCopy ? "true" : "")"
      data-company-id="@(Model?.CompanyId ?? 0)"
      data-trade-invoice-company-id="@TradeInvoiceLayout.TradeInvoiceCompanyId">
    <input type="hidden" id="province-id" />
    <input type="hidden" id="buyer-ntn" />
    <input type="hidden" id="buyer-cnic" />

    <div class="card p-2 mb-2">
        <h6 class="text-primary mb-2 small fw-semibold">Invoice Header</h6>
        <div class="row g-2">
            <div class="col-md-2 col-6">
                <label class="form-label form-label-sm" for="invoice-number">Invoice #</label>
                <input type="text" class="form-control form-control-sm" id="invoice-number" readonly />
            </div>
            <div class="col-md-2 col-6">
                <label class="form-label form-label-sm" for="invoice-date">Date</label>
                <input type="text" class="form-control form-control-sm datepicker" id="invoice-date" required />
            </div>
            <div class="col-md-2 col-6">
                <label class="form-label form-label-sm" for="invoice-type">Type</label>
                <select class="form-select form-select-sm" id="invoice-type">
                    <option value="1">Sales Invoice</option>
                    <option value="2">Debit Note</option>
                    <option value="3">Credit Note</option>
                </select>
            </div>
            <div class="col-md-3 col-6">
                <label class="form-label form-label-sm" for="customer-id">Customer</label>
                <select class="form-select form-select-sm select2" id="customer-id" required>
                    <option value="">— Select —</option>
                </select>
            </div>
            <div class="col-md-3 col-12">
                <label class="form-label form-label-sm" for="scenario-id">FBR Scenario</label>
                <select class="form-select form-select-sm select2" id="scenario-id" required></select>
            </div>
            <div class="col-md-6 col-12">
                <label class="form-label form-label-sm" for="buyer-address">Buyer Address</label>
                <input type="text" class="form-control form-control-sm" id="buyer-address" maxlength="500" />
            </div>
            <div class="col-md-6 col-12">
                <label class="form-label form-label-sm" for="shipping-address">Shipping Address <span class="text-danger">*</span></label>
                <input type="text" class="form-control form-control-sm" id="shipping-address" maxlength="500" required />
            </div>
        </div>
    </div>

    <div class="card p-2 mb-2" id="invoice-lower-section">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="text-primary mb-0 small fw-semibold">Line Items</h6>
            <button type="button" class="btn btn-outline-primary btn-sm py-0 px-2" id="btn-add-line">
                <i class="fa-solid fa-plus me-1"></i>Add Line
            </button>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-compact align-middle mb-0" id="invoice-lines-table">
                <thead class="table-light">
                    <tr>
                        <th>Lot</th>
                        <th>Item</th>
                        <th>Description</th>
                        <th>Stack</th>
                        <th class="text-end">Ctn</th>
                        <th>Carton Desc</th>
                        <th class="text-end">Qty</th>
                        <th>U/M</th>
                        <th class="text-end">Price</th>
                        <th class="tax-line-col text-end">Tax%</th>
                        <th class="text-end">Disc</th>
                        <th class="text-end">Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="invoice-lines-body"></tbody>
            </table>
        </div>
        <p class="text-muted small mt-2 mb-0 d-none" id="no-items-hint">No active items found. Restart the app to seed a demo item automatically.</p>
    </div>

    <div class="row g-2 mb-2">
        <div class="col-md-8">
            <div class="card p-2 h-100">
                <h6 class="text-primary mb-2 small fw-semibold">Supporting Documents</h6>
                <p class="text-muted small mb-1">JPG, PNG, PDF — max 10 MB each, up to 10 files.</p>
                <input type="file" class="form-control form-control-sm" id="invoice-attachments" accept=".jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf" multiple />
                <ul class="list-group list-group-flush mt-2" id="attachment-preview-list"></ul>
                <p class="text-muted small mt-3 mb-0">
                    <i class="fa-solid fa-truck me-1"></i>
                    Delivery challan PDF is available after saving (invoice details → Delivery Challan PDF).
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-2 small">
                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal</span>
                    <span class="text-currency" id="total-subtotal">0.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Discount</span>
                    <span class="text-currency" id="total-discount">0.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2" id="total-tax-row">
                    <span>Tax</span>
                    <span class="text-currency" id="total-tax">0.00</span>
                </div>
                <div class="d-flex justify-content-between mb-2 d-none" id="total-st-tax-row">
                    <span id="total-st-tax-label">Sales Tax (18%)</span>
                    <span class="text-currency" id="total-st-tax">0.00</span>
                </div>
                <div class="d-none mb-2" id="total-ft-tax-row">
                    <div class="d-flex justify-content-between align-items-center gap-2">
                        <span id="total-ft-tax-label" class="flex-shrink-0">Further Tax</span>
                        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                            <div class="d-flex align-items-center gap-1">
                                <input type="number" id="further-tax-rate" class="form-control form-control-xs text-end" style="width:4.5rem" step="0.01" min="0" max="100" title="Further tax rate %" />
                                <span class="text-muted">%</span>
                            </div>
                            <input type="number" id="further-tax-amount" class="form-control form-control-xs text-end" style="width:6.5rem" step="0.01" min="0" title="Further tax amount" />
                        </div>
                    </div>
                </div>
                <hr class="my-2" />
                <div class="d-flex justify-content-between fw-semibold">
                    <span>Net Total</span>
                    <span class="text-currency text-primary" id="total-net">0.00</span>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-danger d-none" id="invoice-form-error"></div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" id="btn-save-invoice">
            <i class="fa-solid fa-floppy-disk me-1"></i>@(isEdit ? "Update Draft Invoice" : "Save Draft Invoice")
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Styles {
    <style>
        .invoice-create-compact .form-label-sm {
            font-size: 0.72rem;
            margin-bottom: 0.15rem;
            color: var(--bs-secondary-color);
        }

        .invoice-create-compact .table-compact {
            font-size: 0.72rem;
        }

        .invoice-create-compact .table-compact th,
        .invoice-create-compact .table-compact td {
            padding: 0.2rem 0.25rem;
            vertical-align: middle;
            white-space: nowrap;
        }

        .invoice-create-compact .table-compact th:nth-child(1),
        .invoice-create-compact .table-compact td:nth-child(1) {
            min-width: 7.5rem;
            width: 7.5rem;
        }

        .invoice-create-compact .table-compact th:nth-child(3),
        .invoice-create-compact .table-compact td:nth-child(3) {
            white-space: normal;
            min-width: 7rem;
        }

        .invoice-create-compact .line-lot-cell .select2-container {
            min-width: 7rem !important;
            width: 100% !important;
        }

        .invoice-create-compact .line-lot-cell .select2-container--bootstrap-5 .select2-selection {
            min-height: calc(1.5em + 0.5rem + 2px);
            padding: 0.25rem 0.45rem;
            font-size: 0.8rem;
        }

        .invoice-create-compact .line-lot-cell .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
            padding-left: 0;
            padding-right: 1.2rem;
            line-height: 1.35;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .invoice-create-compact .form-control-xs,
        .invoice-create-compact .form-select-xs {
            padding: 0.1rem 0.3rem;
            font-size: 0.72rem;
            line-height: 1.25;
            min-height: 1.45rem;
        }

        .invoice-create-compact .form-select-sm.line-lot {
            min-height: calc(1.5em + 0.5rem + 2px);
            font-size: 0.8rem;
        }

        .invoice-create-compact .line-stock-hint {
            font-size: 0.65rem !important;
            line-height: 1.2;
            margin-top: 0.1rem !important;
        }

        .invoice-create-compact .select2-container--bootstrap-5 .select2-selection {
            min-height: calc(1.5em + 0.5rem + 2px);
            padding: 0.2rem 0.4rem;
            font-size: 0.8rem;
        }

        .invoice-create-compact .select2-container--bootstrap-5 .select2-selection--single .select2-selection__rendered {
            padding: 0;
            line-height: 1.4;
        }
    </style>
}

@section Scripts {
    <script src="~/js/modules/lot-stack-line-helper.js" asp-append-version="true"></script>
    <script src="~/js/modules/sales-invoice-create.js" asp-append-version="true"></script>
}
