@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@{
    ViewData["Title"] = "Customers";
    var canCreate = await PermissionService.HasPermissionAsync("Customers.Create");
    var canEdit = await PermissionService.HasPermissionAsync("Customers.Edit");
    var canDelete = await PermissionService.HasPermissionAsync("Customers.Delete");
}

<div id="customer-permissions" class="d-none"
     data-can-create="@canCreate.ToString().ToLower()"
     data-can-edit="@canEdit.ToString().ToLower()"
     data-can-delete="@canDelete.ToString().ToLower()"></div>

@if (TempData["Error"] is string pageError)
{
    <div class="alert alert-danger">@pageError</div>
}

<div id="customer-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Customers</h4>
        <p class="text-muted small mb-0">Manage buyers for sales invoices and FBR digital invoicing</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="btn-add-customer" permission="Customers.Create">
        <i class="fa-solid fa-user-plus me-1"></i>New Customer
    </button>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table table-hover w-100" id="customers-table">
            <thead>
                <tr>
                    <th>Buyer ID</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Province</th>
                    <th>NTN</th>
                    <th>Phone</th>
                    <th class="text-end">Opening</th>
                    <th class="text-end">Balance</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="customerModal" tabindex="-1" aria-labelledby="customerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="customerModalLabel">Customer</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="customer-form">
                <div class="modal-body">
                    <input type="hidden" id="customer-id" />
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label" for="buyer-id">Buyer ID</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="buyer-id" required maxlength="50" />
                                <button type="button" class="btn btn-outline-secondary" id="btn-generate-buyer-id" title="Generate ID">
                                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label" for="buyer-name">Buyer Name</label>
                            <input type="text" class="form-control" id="buyer-name" required maxlength="200" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" for="customer-type">Customer Type</label>
                            <select class="form-select" id="customer-type" required>
                                <option value="1">Registered</option>
                                <option value="2">Unregistered</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label" for="invoice-type">Invoice Type</label>
                            <select class="form-select" id="invoice-type" required>
                                <option value="1">Sales Invoice</option>
                                <option value="2">Debit Note</option>
                                <option value="3">Credit Note</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="scenario-id">FBR Scenario</label>
                            <select class="form-select select2" id="scenario-id" required></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="province-id">Province</label>
                            <select class="form-select select2" id="province-id">
                                <option value="">— Select —</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="opening-balance">Opening Balance (PKR)</label>
                            <input type="number" class="form-control" id="opening-balance" step="0.01" value="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="ntn">NTN</label>
                            <input type="text" class="form-control" id="ntn" maxlength="50" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="cnic">CNIC</label>
                            <input type="text" class="form-control" id="cnic" maxlength="20" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="strn">STRN</label>
                            <input type="text" class="form-control" id="strn" maxlength="50" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="phone">Phone</label>
                            <input type="text" class="form-control" id="phone" maxlength="30" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="mobile">Mobile</label>
                            <input type="text" class="form-control" id="mobile" maxlength="30" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="email">Email</label>
                            <input type="email" class="form-control" id="email" maxlength="100" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="address">Address</label>
                            <textarea class="form-control" id="address" rows="2" maxlength="500"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="customer-active" checked />
                                <label class="form-check-label" for="customer-active">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-danger d-none mt-3" id="customer-form-error"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="btn-save-customer">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/customers.js" asp-append-version="true"></script>
}
