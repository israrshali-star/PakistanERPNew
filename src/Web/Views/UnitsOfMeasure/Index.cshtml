@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@{
    ViewData["Title"] = "Units of Measure";
    var canCreate = await PermissionService.HasPermissionAsync("Items.Create");
    var canEdit = await PermissionService.HasPermissionAsync("Items.Edit");
    var canDelete = await PermissionService.HasPermissionAsync("Items.Delete");
}

<div id="uom-permissions" class="d-none"
     data-can-create="@canCreate.ToString().ToLower()"
     data-can-edit="@canEdit.ToString().ToLower()"
     data-can-delete="@canDelete.ToString().ToLower()"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Units of Measure</h4>
        <p class="text-muted small mb-0">Define units used on items (KG, PCS, CTN, etc.)</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="btn-add-uom" permission="Items.Create">
        <i class="fa-solid fa-ruler me-1"></i>New Unit
    </button>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table table-hover w-100" id="uom-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Symbol</th>
                    <th class="text-end">Items</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="uomModal" tabindex="-1" aria-labelledby="uomModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="uomModalLabel">Unit of Measure</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="uom-form">
                <div class="modal-body">
                    <input type="hidden" id="uom-id" />
                    <div class="mb-3">
                        <label class="form-label" for="uom-name">Name</label>
                        <input type="text" class="form-control" id="uom-name" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="uom-symbol">Symbol</label>
                        <input type="text" class="form-control" id="uom-symbol" maxlength="20" placeholder="e.g. PCS" />
                    </div>
                    <div class="alert alert-danger d-none" id="uom-form-error"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/units-of-measure.js" asp-append-version="true"></script>
}
