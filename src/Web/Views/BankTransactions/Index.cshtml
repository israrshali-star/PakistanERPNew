@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@{
    ViewData["Title"] = "Bank Transactions";
    var canCreate = await PermissionService.HasPermissionAsync("Banking.Create");
}

<div id="bank-txn-permissions" class="d-none" data-can-create="@canCreate.ToString().ToLower()"></div>
<div id="bank-txn-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Bank Transactions</h4>
        <p class="text-muted small mb-0">Deposits, withdrawals, and inter-account transfers</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="btn-add-bank-txn" permission="Banking.Create">
        <i class="fa-solid fa-money-bill-transfer me-1"></i>New Transaction
    </button>
</div>

<div class="card p-3 mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label" for="filter-bank-id">Filter by Bank</label>
            <select class="form-select" id="filter-bank-id">
                <option value="">All banks</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-outline-primary" id="btn-apply-filter">Apply</button>
        </div>
    </div>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table table-hover w-100" id="bank-transactions-table">
            <thead>
                <tr>
                    <th>Bank</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Transfer To</th>
                    <th class="text-end">Amount</th>
                    <th>Description</th>
                    <th>Reconciled</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="bankTxnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary">New Bank Transaction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="bank-txn-form">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="txn-bank-id">Bank Account</label>
                            <select class="form-select select2" id="txn-bank-id" required>
                                <option value="">— Select bank —</option>
                            </select>
                            <div class="form-text" id="txn-bank-balance"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="txn-type">Type</label>
                            <select class="form-select" id="txn-type" required>
                                <option value="1">Deposit</option>
                                <option value="2">Withdrawal</option>
                                <option value="3">Transfer</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="txn-date">Date</label>
                            <input type="date" class="form-control" id="txn-date" required />
                        </div>
                        <div class="col-md-4 transfer-fields d-none">
                            <label class="form-label" for="txn-transfer-to-id">Transfer To</label>
                            <select class="form-select select2" id="txn-transfer-to-id">
                                <option value="">— Select bank —</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="txn-amount">Amount (PKR)</label>
                            <input type="number" class="form-control" id="txn-amount" step="0.01" min="0.01" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="txn-cheque-number">Cheque #</label>
                            <input type="text" class="form-control" id="txn-cheque-number" maxlength="50" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="txn-cheque-date">Cheque Date</label>
                            <input type="date" class="form-control" id="txn-cheque-date" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="txn-description">Description</label>
                            <textarea class="form-control" id="txn-description" rows="2" maxlength="500"></textarea>
                        </div>
                    </div>
                    <div class="alert alert-danger d-none mt-3" id="bank-txn-form-error"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Transaction</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/bank-transactions.js" asp-append-version="true"></script>
}
