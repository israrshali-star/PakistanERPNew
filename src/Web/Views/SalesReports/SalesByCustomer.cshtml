@{
    ViewData["Title"] = "Sales by Customer";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-1">Sales by Customer</h4>
        <p class="text-muted small mb-0">Customer-wise sales totals for a date range</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-print-report">
            <i class="fa-solid fa-print me-1"></i>Print / Save PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3 no-print"></div>

<div class="card p-3 mb-3 no-print">
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label" for="filter-from">From Date</label>
            <input type="date" class="form-control" id="filter-from" />
        </div>
        <div class="col-md-2">
            <label class="form-label" for="filter-to">To Date</label>
            <input type="date" class="form-control" id="filter-to" />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="filter-customer">Customer</label>
            <select class="form-select select2" id="filter-customer">
                <option value="">All customers</option>
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="filter-posted-only" checked />
                <label class="form-check-label" for="filter-posted-only">Posted only</label>
            </div>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-primary w-100" id="btn-load-report">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Load
            </button>
        </div>
    </div>
</div>

<div class="card p-3 report-print-area report-print-landscape" id="report-content">
    <div class="text-center mb-4">
        <h5 class="text-primary mb-1">Sales by Customer</h5>
        <p class="text-muted small mb-0" id="report-period">Select dates and click Load</p>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th>Customer Code</th>
                    <th>Customer Name</th>
                    <th class="text-end">Invoices</th>
                    <th class="text-end">Subtotal</th>
                    <th class="text-end">Discount</th>
                    <th class="text-end">Tax</th>
                    <th class="text-end">Net</th>
                </tr>
            </thead>
            <tbody id="report-lines">
                <tr><td colspan="7" class="text-muted text-center">No data loaded.</td></tr>
            </tbody>
            <tfoot id="report-footer" class="d-none table-light">
                <tr>
                    <th colspan="3" class="text-end">Totals</th>
                    <th class="text-end" id="report-total-subtotal">0.00</th>
                    <th class="text-end" id="report-total-discount">0.00</th>
                    <th class="text-end" id="report-total-tax">0.00</th>
                    <th class="text-end" id="report-total-net">0.00</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/report-print.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/modules/report-print-common.js" asp-append-version="true"></script>
    <script src="~/js/modules/sales-report-by-customer.js" asp-append-version="true"></script>
}
