@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@{
    ViewData["Title"] = "Vendors";
    var canCreate = await PermissionService.HasPermissionAsync("Vendors.Create");
    var canEdit = await PermissionService.HasPermissionAsync("Vendors.Edit");
    var canDelete = await PermissionService.HasPermissionAsync("Vendors.Delete");
}

<div id="vendor-permissions" class="d-none"
     data-can-create="@canCreate.ToString().ToLower()"
     data-can-edit="@canEdit.ToString().ToLower()"
     data-can-delete="@canDelete.ToString().ToLower()"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Vendors</h4>
        <p class="text-muted small mb-0">Manage suppliers for purchase bills and accounts payable</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="btn-add-vendor" permission="Vendors.Create">
        <i class="fa-solid fa-truck me-1"></i>New Vendor
    </button>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table table-hover w-100" id="vendors-table">
            <thead>
                <tr>
                    <th>Vendor Code</th>
                    <th>Name</th>
                    <th>Province</th>
                    <th>NTN</th>
                    <th>Phone</th>
                    <th class="text-end">Tax %</th>
                    <th class="text-end">Opening</th>
                    <th class="text-end">Balance</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="vendorModal" tabindex="-1" aria-labelledby="vendorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="vendorModalLabel">Vendor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="vendor-form">
                <div class="modal-body">
                    <input type="hidden" id="vendor-id" />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="vendor-code">Vendor Code</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="vendor-code" required maxlength="50" />
                                <button type="button" class="btn btn-outline-secondary" id="btn-generate-vendor-code" title="Generate code">
                                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label" for="vendor-name">Vendor Name</label>
                            <input type="text" class="form-control" id="vendor-name" required maxlength="200" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="province-id">Province</label>
                            <select class="form-select select2" id="province-id">
                                <option value="">— Select —</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="default-tax-rate">Default Sales Tax Rate (%)</label>
                            <input type="number" class="form-control" id="default-tax-rate" step="0.01" min="0" max="100" value="18" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="opening-balance">Opening Balance (PKR)</label>
                            <input type="number" class="form-control" id="opening-balance" step="0.01" value="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="ntn">NTN</label>
                            <input type="text" class="form-control" id="ntn" maxlength="50" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="phone">Phone</label>
                            <input type="text" class="form-control" id="phone" maxlength="30" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="email">Email</label>
                            <input type="email" class="form-control" id="email" maxlength="100" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="address">Address</label>
                            <textarea class="form-control" id="address" rows="2" maxlength="500"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="vendor-active" checked />
                                <label class="form-check-label" for="vendor-active">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-danger d-none mt-3" id="vendor-form-error"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="btn-save-vendor">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/vendors.js" asp-append-version="true"></script>
}
