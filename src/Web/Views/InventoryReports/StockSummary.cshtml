@{
    ViewData["Title"] = "Stock Summary Report";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-1">Stock Summary</h4>
        <p class="text-muted small mb-0">Current stock on hand with purchase-rate valuation</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-print-report">
            <i class="fa-solid fa-print me-1"></i>Print / Save PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3 no-print"></div>

<div class="card p-3 mb-3 no-print">
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label" for="filter-date-preset">Dates</label>
            <select class="form-select" id="filter-date-preset">
                <option value="custom">Custom</option>
                <option value="today">Today</option>
                <option value="this-month">This Month</option>
                <option value="last-month">Last Month</option>
                <option value="this-quarter">This Quarter</option>
                <option value="last-quarter">Last Quarter</option>
                <option value="this-year">This Fiscal Year</option>
                <option value="last-year">Last Fiscal Year</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label" for="filter-as-of">As of</label>
            <input type="date" class="form-control" id="filter-as-of" />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="filter-category">Category</label>
            <select class="form-select" id="filter-category">
                <option value="">All categories</option>
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="filter-active-only" checked />
                <label class="form-check-label" for="filter-active-only">Active items only</label>
            </div>
        </div>
        <div class="col-md-2">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="filter-hide-zero-qoh" />
                <label class="form-check-label" for="filter-hide-zero-qoh">Hide Zero QOH</label>
            </div>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-primary" id="btn-load-report">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Load Report
            </button>
        </div>
    </div>
</div>

<div class="card p-4 report-print-area" id="report-content">
    <div class="text-center mb-4">
        <h5 class="text-primary mb-1">Stock Summary Report</h5>
        <p class="text-muted small mb-0" id="report-period">Click Load Report to generate</p>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th>Item Code</th>
                    <th>Item Name</th>
                    <th>Category</th>
                    <th>UOM</th>
                    <th class="text-end">On Hand</th>
                    <th class="text-end">Cartons</th>
                    <th class="text-end">Min</th>
                    <th class="text-end">Reorder</th>
                    <th class="text-end">Rate</th>
                    <th class="text-end">Value</th>
                </tr>
            </thead>
            <tbody id="report-lines">
                <tr><td colspan="10" class="text-muted text-center">No data loaded.</td></tr>
            </tbody>
            <tfoot id="report-footer" class="d-none table-light">
                <tr>
                    <th colspan="4" class="text-end">Totals</th>
                    <th class="text-end" id="report-total-stock">0.00</th>
                    <th class="text-end" id="report-total-cartons">0</th>
                    <th colspan="3"></th>
                    <th class="text-end" id="report-total-value">0.00</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        @@media print {
            .sidebar, .top-navbar, .content-header, .app-footer, .no-print { display: none !important; }
            .main-wrapper { margin: 0 !important; }
            .content-area { padding: 0 !important; }
            .report-print-area { border: none !important; box-shadow: none !important; }
        }
    </style>
}

@section Scripts {
    <script src="~/js/modules/inventory-report-stock-summary.js" asp-append-version="true"></script>
}
