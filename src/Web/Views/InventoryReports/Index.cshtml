@{
    ViewData["Title"] = "Inventory Reports";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h4 class="text-primary mb-0">Inventory Reports</h4>
        <p class="text-muted small mb-0">Stock levels, alerts, and movement history</p>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="d-flex align-items-start gap-3">
                <div class="text-primary fs-3"><i class="fa-solid fa-boxes-stacked"></i></div>
                <div class="flex-grow-1">
                    <h6 class="text-primary mb-1">Stock Summary</h6>
                    <p class="text-muted small mb-3">Current stock on hand with valuation by purchase rate</p>
                    <a asp-action="StockSummary" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i>Open Report
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="d-flex align-items-start gap-3">
                <div class="text-info fs-3"><i class="fa-solid fa-layer-group"></i></div>
                <div class="flex-grow-1">
                    <h6 class="text-primary mb-1">Stack-Wise Stock</h6>
                    <p class="text-muted small mb-3">Stock on hand by lot and stack with carton and weight totals</p>
                    <a asp-action="StackWiseStock" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i>Open Report
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="d-flex align-items-start gap-3">
                <div class="text-warning fs-3"><i class="fa-solid fa-triangle-exclamation"></i></div>
                <div class="flex-grow-1">
                    <h6 class="text-primary mb-1">Low Stock Alert</h6>
                    <p class="text-muted small mb-3">Items at or below minimum stock or reorder level</p>
                    <a asp-action="LowStock" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i>Open Report
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="d-flex align-items-start gap-3">
                <div class="text-success fs-3"><i class="fa-solid fa-arrows-rotate"></i></div>
                <div class="flex-grow-1">
                    <h6 class="text-primary mb-1">Stock Movement</h6>
                    <p class="text-muted small mb-3">Stock in, out, and adjustments by date range</p>
                    <a asp-action="StockMovement" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i>Open Report
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            $.getJSON('/api/company/current').fail(function () {
                $('#report-company-warning')
                    .removeClass('d-none')
                    .text('Select a company from the top navbar to run inventory reports.');
            });
        })();
    </script>
}
