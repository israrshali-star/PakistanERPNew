@{
    ViewData["Title"] = "Stock Movement Report";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-1">Stock Movement</h4>
        <p class="text-muted small mb-0">Stock in, out, and adjustments for a date range</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-print-report">
            <i class="fa-solid fa-print me-1"></i>Print / Save PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3 no-print"></div>

<div class="card p-3 mb-3 no-print">
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label" for="filter-from">From Date</label>
            <input type="date" class="form-control" id="filter-from" />
        </div>
        <div class="col-md-2">
            <label class="form-label" for="filter-to">To Date</label>
            <input type="date" class="form-control" id="filter-to" />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="filter-item">Item</label>
            <select class="form-select select2" id="filter-item">
                <option value="">All items</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label" for="filter-warehouse">Warehouse</label>
            <select class="form-select select2" id="filter-warehouse">
                <option value="">All warehouses</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-primary w-100" id="btn-load-report">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Load
            </button>
        </div>
    </div>
</div>

<div class="card p-3 report-print-area report-print-landscape" id="report-content">
    <div class="text-center mb-4">
        <h5 class="text-primary mb-1">Stock Movement Report</h5>
        <p class="text-muted small mb-0" id="report-period">Select a date range and click Load</p>
        <p class="text-muted small mb-0" id="report-filters"></p>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Ref #</th>
                    <th>Type</th>
                    <th>Item</th>
                    <th>Stack</th>
                    <th>Lot</th>
                    <th>Warehouse</th>
                    <th class="text-end">Qty In</th>
                    <th class="text-end">Qty Out</th>
                    <th class="text-end">Ctn In</th>
                    <th class="text-end">Ctn Out</th>
                    <th class="text-end">Adj</th>
                    <th class="text-end">Cost</th>
                </tr>
            </thead>
            <tbody id="report-lines">
                <tr><td colspan="13" class="text-muted text-center">No data loaded.</td></tr>
            </tbody>
            <tfoot id="report-footer" class="d-none table-light">
                <tr>
                    <th colspan="7" class="text-end">Totals</th>
                    <th class="text-end" id="report-total-in">0.00</th>
                    <th class="text-end" id="report-total-out">0.00</th>
                    <th class="text-end" id="report-total-ctn-in">0</th>
                    <th class="text-end" id="report-total-ctn-out">0</th>
                    <th colspan="2"></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/report-print.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/modules/report-print-common.js" asp-append-version="true"></script>
    <script src="~/js/modules/inventory-report-stock-movement.js" asp-append-version="true"></script>
}
