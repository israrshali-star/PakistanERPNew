@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@{
    ViewData["Title"] = "Stock Transactions";
    var canCreate = await PermissionService.HasPermissionAsync("Inventory.Create");
}

<div id="stock-permissions" class="d-none" data-can-create="@canCreate.ToString().ToLower()"></div>
<div id="stock-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Stock Transactions</h4>
        <p class="text-muted small mb-0">Record stock in, stock out, adjustments, and opening balances</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="btn-add-stock-txn" permission="Inventory.Create">
        <i class="fa-solid fa-arrows-rotate me-1"></i>New Transaction
    </button>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table table-hover w-100" id="stock-transactions-table">
            <thead>
                <tr>
                    <th>Reference</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Item</th>
                    <th>Warehouse</th>
                    <th class="text-end">Qty</th>
                    <th class="text-end">Cost</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="stockTxnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary">New Stock Transaction</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="stock-txn-form">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label" for="txn-reference">Reference</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="txn-reference" maxlength="50" />
                                <button type="button" class="btn btn-outline-secondary" id="btn-generate-txn-ref" title="Generate reference">
                                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="txn-date">Date</label>
                            <input type="date" class="form-control" id="txn-date" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="txn-type">Type</label>
                            <select class="form-select" id="txn-type" required>
                                <option value="1">Stock In</option>
                                <option value="2">Stock Out</option>
                                <option value="3">Adjustment</option>
                                <option value="4">Opening</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="txn-item-id">Item</label>
                            <select class="form-select select2" id="txn-item-id" required>
                                <option value="">— Select item —</option>
                            </select>
                            <div class="form-text" id="txn-item-stock"></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="txn-warehouse-id">Warehouse</label>
                            <select class="form-select select2" id="txn-warehouse-id" required>
                                <option value="">— Select warehouse —</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="txn-quantity">Quantity</label>
                            <input type="number" class="form-control" id="txn-quantity" step="0.01" required />
                            <div class="form-text" id="txn-qty-hint">Positive for in/opening/out; signed for adjustment</div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="txn-unit-cost">Unit Cost (PKR)</label>
                            <input type="number" class="form-control" id="txn-unit-cost" step="0.01" min="0" value="0" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="txn-stack-no">Stack No</label>
                            <input type="text" class="form-control" id="txn-stack-no" maxlength="50" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label" for="txn-lot-no">Lot No</label>
                            <input type="text" class="form-control" id="txn-lot-no" maxlength="50" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="txn-notes">Notes</label>
                            <textarea class="form-control" id="txn-notes" rows="2" maxlength="500"></textarea>
                        </div>
                    </div>
                    <div class="alert alert-danger d-none mt-3" id="stock-txn-form-error"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Transaction</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/inventory-transactions.js" asp-append-version="true"></script>
}
