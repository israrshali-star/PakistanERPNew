@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@{
    ViewData["Title"] = "Fiscal Years";
    var canEdit = await PermissionService.HasPermissionAsync("Settings.Edit");
}

<div id="fiscal-year-permissions" class="d-none"
     data-can-edit="@canEdit.ToString().ToLower()"></div>

<div id="fiscal-year-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Fiscal Years</h4>
        <p class="text-muted small mb-0">Manage accounting periods and active fiscal year</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="btn-add-fiscal-year" permission="Settings.Edit">
        <i class="fa-solid fa-calendar-plus me-1"></i>New Fiscal Year
    </button>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table table-hover w-100" id="fiscal-years-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Active</th>
                    <th>Closed</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="fiscalYearModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="fiscalYearModalLabel">Fiscal Year</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="fiscal-year-form">
                <div class="modal-body">
                    <input type="hidden" id="fiscal-year-id" />
                    <div class="mb-3">
                        <label class="form-label" for="fiscal-year-code">Code</label>
                        <input type="text" class="form-control" id="fiscal-year-code" maxlength="50" placeholder="FY2025-26 (auto if blank)" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="fiscal-year-name">Name</label>
                        <input type="text" class="form-control" id="fiscal-year-name" required maxlength="200" />
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label" for="fiscal-year-start">Start Date</label>
                            <input type="date" class="form-control" id="fiscal-year-start" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="fiscal-year-end">End Date</label>
                            <input type="date" class="form-control" id="fiscal-year-end" required />
                        </div>
                    </div>
                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="fiscal-year-active" />
                        <label class="form-check-label" for="fiscal-year-active">Active</label>
                    </div>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="fiscal-year-closed" />
                        <label class="form-check-label" for="fiscal-year-closed">Closed</label>
                    </div>
                    <div class="alert alert-danger d-none mt-3" id="fiscal-year-form-error"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/fiscal-years.js" asp-append-version="true"></script>
}
