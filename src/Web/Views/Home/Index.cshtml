@{
    ViewData["Title"] = "Dashboard";
    var company = ViewBag.Company as PakistanAccountingERP.Application.DTOs.CompanyDto;
}

<div class="row g-3 mb-4" id="dashboard-kpis">
    <div class="col-6 col-lg-4 col-xl">
        <div class="card card-kpi p-3">
            <div class="kpi-label">Today's Sales</div>
            <div class="kpi-value text-currency" data-kpi="todaySales">—</div>
        </div>
    </div>
    <div class="col-6 col-lg-4 col-xl">
        <div class="card card-kpi p-3">
            <div class="kpi-label">This Month's Sales</div>
            <div class="kpi-value text-currency" data-kpi="monthSales">—</div>
        </div>
    </div>
    <div class="col-6 col-lg-4 col-xl">
        <div class="card card-kpi p-3">
            <div class="kpi-label">Outstanding Receivables</div>
            <div class="kpi-value text-currency" data-kpi="outstandingReceivables">—</div>
        </div>
    </div>
    <div class="col-6 col-lg-6 col-xl">
        <div class="card card-kpi p-3">
            <div class="kpi-label">AP Closing Balance</div>
            <div class="kpi-value text-currency" data-kpi="outstandingPayables">—</div>
        </div>
    </div>
    <div class="col-6 col-lg-6 col-xl">
        <div class="card card-kpi p-3">
            <div class="kpi-label">Inventory Value</div>
            <div class="kpi-value text-currency" data-kpi="inventoryValue">—</div>
        </div>
    </div>
    <div class="col-6 col-lg-6 col-xl">
        <div class="card card-kpi p-3">
            <div class="kpi-label">Cash &amp; Bank (COA)</div>
            <div class="kpi-value text-currency" data-kpi="cashAndBankBalance">—</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card p-3">
            <h5 class="card-title text-primary mb-1">Daily Sales (Last 30 Days)</h5>
            <p class="text-muted small mb-3">Posted invoice cartons sold by day</p>
            <canvas id="dailySalesChart" height="140"></canvas>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card p-3">
            <h5 class="card-title text-primary mb-1">Profit &amp; Loss Trend (Last 12 Months)</h5>
            <p class="text-muted small mb-3">Green = profit, red = loss (from general ledger)</p>
            <canvas id="profitLossChart" height="140"></canvas>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card p-3">
            <h5 class="card-title text-primary mb-3">Monthly Cartons Sold (Last 12 Months)</h5>
            <canvas id="salesChart" height="120"></canvas>
        </div>
        <div class="card p-3 mt-3">
            <h5 class="card-title text-primary mb-3">Recent Invoices</h5>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0" id="recent-invoices-table">
                    <thead>
                        <tr>
                            <th>Invoice #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th class="text-end">Net Total</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="5" class="text-muted text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card p-3">
            <h5 class="card-title text-primary mb-3">Welcome</h5>
            <p class="mb-1"><strong>@ViewBag.UserName</strong></p>
            @if (company is not null)
            {
                <p class="text-muted mb-0">@company.CompanyName</p>
            }
        </div>
        <div class="card p-3 mt-3">
            <h6 class="text-primary">Customer Balances (Dr &amp; Cr)</h6>
            <p class="text-muted small mb-2">Top debit (receivable) and credit balances</p>
            <div class="dashboard-customer-balances-scroll">
                <ul class="list-group list-group-flush" id="top-customers-list">
                    <li class="list-group-item text-muted small">Loading...</li>
                </ul>
            </div>
        </div>
        <div class="card p-3 mt-3" id="bank-closing-balances-card">
            <h6 class="text-primary">Cash &amp; Bank Balances (COA)</h6>
            <p class="text-muted small mb-2">GL closing balance per cash and bank account — same as Chart of Accounts.</p>
            <div class="table-responsive dashboard-customer-balances-scroll">
                <table class="table table-sm table-hover mb-0" id="bank-closing-balances-table">
                    <thead>
                        <tr>
                            <th>Account</th>
                            <th class="text-end">Closing Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="2" class="text-muted text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card p-3 mt-3" id="ap-closing-balances-card">
            <h6 class="text-primary">AP Closing Balance by Company</h6>
            <p class="text-muted small mb-2">Account 20000 — net vendor payable (W/H tax on 12810). Negative = owed.</p>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0" id="ap-closing-balances-table">
                    <thead>
                        <tr>
                            <th>Company</th>
                            <th class="text-end">Closing Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="2" class="text-muted text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card p-3 mt-3">
            <h6 class="text-primary">Low Stock Items</h6>
            <ul class="list-group list-group-flush" id="low-stock-list">
                <li class="list-group-item text-muted small">Loading...</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
