@{
    ViewData["Title"] = "Trial Balance";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-1">Trial Balance</h4>
        <p class="text-muted small mb-0">Closing debit and credit balances by account</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-print-report">
            <i class="fa-solid fa-print me-1"></i>Print / Save PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3 no-print"></div>

<div class="card p-3 mb-3 no-print">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label" for="filter-from">From Date</label>
            <input type="date" class="form-control" id="filter-from" />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="filter-to">To Date</label>
            <input type="date" class="form-control" id="filter-to" />
        </div>
        <div class="col-md-3">
            <button type="button" class="btn btn-primary w-100" id="btn-load-report">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Load
            </button>
        </div>
    </div>
</div>

<div class="card p-4 report-print-area report-proforma" id="report-content">
    <div class="report-proforma-header">
        <div class="report-proforma-company" id="report-company-name"></div>
        <div class="report-proforma-title">Trial Balance</div>
        <p class="report-proforma-period" id="report-period">Select dates and click Load</p>
    </div>

    <table class="report-proforma-table">
        <thead>
            <tr>
                <th class="col-label"></th>
                <th class="col-debit text-end">Debit</th>
                <th class="col-credit text-end">Credit</th>
            </tr>
        </thead>
        <tbody id="report-lines">
            <tr><td colspan="3" class="text-muted text-center">No data loaded.</td></tr>
        </tbody>
    </table>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/financial-report-proforma.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/modules/financial-report-common.js" asp-append-version="true"></script>
    <script src="~/js/modules/financial-report-trial-balance.js" asp-append-version="true"></script>
}
