@{
    ViewData["Title"] = "Financial Reports";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <div>
        <h4 class="text-primary mb-0">Financial Reports</h4>
        <p class="text-muted small mb-0">Trial balance, profit &amp; loss, balance sheet, and AR aging from posted transactions</p>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="d-flex align-items-start gap-3">
                <div class="text-primary fs-3"><i class="fa-solid fa-scale-balanced"></i></div>
                <div class="flex-grow-1">
                    <h6 class="text-primary mb-1">Trial Balance</h6>
                    <p class="text-muted small mb-3">Opening, period activity, and closing debit/credit balances by account</p>
                    <a asp-action="TrialBalance" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i>Open Report
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="d-flex align-items-start gap-3">
                <div class="text-success fs-3"><i class="fa-solid fa-chart-line"></i></div>
                <div class="flex-grow-1">
                    <h6 class="text-primary mb-1">Profit &amp; Loss</h6>
                    <p class="text-muted small mb-3">Revenue, cost of goods sold, expenses, and net profit for a period</p>
                    <a asp-action="ProfitAndLoss" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i>Open Report
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="d-flex align-items-start gap-3">
                <div class="text-warning fs-3"><i class="fa-solid fa-landmark"></i></div>
                <div class="flex-grow-1">
                    <h6 class="text-primary mb-1">Balance Sheet</h6>
                    <p class="text-muted small mb-3">Assets, liabilities, and equity as of a selected date</p>
                    <a asp-action="BalanceSheet" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i>Open Report
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="d-flex align-items-start gap-3">
                <div class="text-info fs-3"><i class="fa-solid fa-hourglass-half"></i></div>
                <div class="flex-grow-1">
                    <h6 class="text-primary mb-1">AR Aging Summary</h6>
                    <p class="text-muted small mb-3">Outstanding receivables by customer in aging buckets</p>
                    <a asp-action="ArAgingSummary" class="btn btn-outline-primary btn-sm">
                        <i class="fa-solid fa-arrow-right me-1"></i>Open Report
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            $.getJSON('/api/company/current').fail(function () {
                $('#report-company-warning')
                    .removeClass('d-none')
                    .text('Select a company from the top navbar to run financial reports.');
            });
        })();
    </script>
}
