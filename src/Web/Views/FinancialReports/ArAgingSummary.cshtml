@{
    ViewData["Title"] = "AR Aging Summary";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-1">AR Aging Summary</h4>
        <p class="text-muted small mb-0">Outstanding accounts receivable by customer and aging bucket</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-print-report">
            <i class="fa-solid fa-print me-1"></i>Print / Save PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3 no-print"></div>

<div class="card p-3 mb-3 no-print">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label" for="filter-as-of">As of Date</label>
            <input type="date" class="form-control" id="filter-as-of" />
        </div>
        <div class="col-md-3">
            <button type="button" class="btn btn-primary w-100" id="btn-load-report">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Load
            </button>
        </div>
    </div>
</div>

<div class="card p-4 report-print-area" id="report-content">
    <div class="text-center mb-4">
        <h5 class="text-primary mb-1">Accounts Receivable Aging Summary</h5>
        <p class="text-muted small mb-0" id="report-period">Select a date and click Load</p>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th>Customer Code</th>
                    <th>Customer Name</th>
                    <th class="text-end">Opening</th>
                    <th class="text-end">Current</th>
                    <th class="text-end">31–60 Days</th>
                    <th class="text-end">61–90 Days</th>
                    <th class="text-end">90+ Days</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody id="report-lines">
                <tr><td colspan="8" class="text-muted text-center">No data loaded.</td></tr>
            </tbody>
            <tfoot id="report-footer" class="d-none table-light">
                <tr>
                    <th colspan="2" class="text-end">Totals</th>
                    <th class="text-end" id="report-total-opening">0.00</th>
                    <th class="text-end" id="report-total-current">0.00</th>
                    <th class="text-end" id="report-total-31-60">0.00</th>
                    <th class="text-end" id="report-total-61-90">0.00</th>
                    <th class="text-end" id="report-total-over-90">0.00</th>
                    <th class="text-end" id="report-total-grand">0.00</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        @@media print {
            .sidebar, .top-navbar, .content-header, .app-footer, .no-print { display: none !important; }
            .main-wrapper { margin: 0 !important; }
            .content-area { padding: 0 !important; }
            .report-print-area { border: none !important; box-shadow: none !important; }
        }
    </style>
}

@section Scripts {
    <script src="~/js/modules/financial-report-ar-aging.js" asp-append-version="true"></script>
}
