@{
    ViewData["Title"] = "AR Aging Summary";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-1">AR Aging Summary</h4>
        <p class="text-muted small mb-0">Outstanding accounts receivable by customer and aging bucket</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-print-report">
            <i class="fa-solid fa-print me-1"></i>Print / Save PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3 no-print"></div>

<div class="card p-3 mb-3 no-print">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label" for="filter-as-of">As of Date</label>
            <input type="date" class="form-control" id="filter-as-of" />
        </div>
        <div class="col-md-3">
            <button type="button" class="btn btn-primary w-100" id="btn-load-report">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Load
            </button>
        </div>
    </div>
</div>

<div class="card p-3 report-print-area report-proforma report-proforma-trial-balance" id="report-content">
    <div class="report-proforma-header">
        <div class="report-proforma-company" id="report-company-name"></div>
        <div class="report-proforma-title">Accounts Receivable Aging Summary</div>
        <p class="report-proforma-period" id="report-period">Select a date and click Load</p>
    </div>

    <table class="report-proforma-table report-proforma-table-wide">
        <thead>
            <tr>
                <th>Code</th>
                <th>Customer</th>
                <th class="text-end">Opening</th>
                <th class="text-end">Current</th>
                <th class="text-end">31-60</th>
                <th class="text-end">61-90</th>
                <th class="text-end">90+</th>
                <th class="text-end">Total</th>
            </tr>
        </thead>
        <tbody id="report-lines">
            <tr><td colspan="8" class="text-muted text-center">No data loaded.</td></tr>
        </tbody>
        <tfoot id="report-footer" class="d-none">
            <tr class="row-total">
                <td colspan="2" class="text-end">Totals</td>
                <td class="text-end" id="report-total-opening">0.00</td>
                <td class="text-end" id="report-total-current">0.00</td>
                <td class="text-end" id="report-total-31-60">0.00</td>
                <td class="text-end" id="report-total-61-90">0.00</td>
                <td class="text-end" id="report-total-over-90">0.00</td>
                <td class="text-end" id="report-total-grand">0.00</td>
            </tr>
        </tfoot>
    </table>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/financial-report-proforma.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/modules/financial-report-common.js" asp-append-version="true"></script>
    <script src="~/js/modules/financial-report-ar-aging.js" asp-append-version="true"></script>
}
