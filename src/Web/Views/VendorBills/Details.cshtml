@using PakistanAccountingERP.Application.DTOs
@using PakistanAccountingERP.Application.Interfaces.Services
@using PakistanAccountingERP.Domain.Enums
@inject IPermissionService PermissionService
@model VendorBillDetailDto
@{
    ViewData["Title"] = "Bill " + Model.BillNumber;
    var canEdit = await PermissionService.HasPermissionAsync("Purchase.Edit");
    var canDelete = await PermissionService.HasPermissionAsync("Purchase.Delete");
    var canApprove = canEdit && Model.Status == BillStatus.Draft;
    var canDeleteBill = canDelete && Model.Status == BillStatus.Draft;
    var canRevertToDraft = canEdit && Model.Status == BillStatus.Approved;
}

<div id="bill-detail"
     data-id="@Model.Id"
     data-can-approve="@canApprove.ToString().ToLower()"
     data-can-delete="@canDeleteBill.ToString().ToLower()"
     data-can-revert-to-draft="@canRevertToDraft.ToString().ToLower()"
     data-can-edit-attachments="@(canEdit && Model.Status == BillStatus.Draft).ToString().ToLower()"></div>

<div id="bill-action-message" class="alert d-none mb-3"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">@Model.BillNumber</h4>
        <p class="text-muted small mb-0">@Model.VendorCode — @Model.VendorName</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to list
        </a>
        @if (canApprove)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-pen me-1"></i>Edit Draft
            </a>
            <button type="button" class="btn btn-success btn-sm" id="btn-approve-bill">
                <i class="fa-solid fa-check me-1"></i>Approve & Post to GL
            </button>
        }
        @if (canRevertToDraft)
        {
            <button type="button" class="btn btn-outline-warning btn-sm" id="btn-revert-bill">
                <i class="fa-solid fa-rotate-left me-1"></i>Reopen for Editing
            </button>
        }
        @if (canDeleteBill)
        {
            <button type="button" class="btn btn-outline-danger btn-sm" id="btn-delete-bill">
                <i class="fa-solid fa-trash me-1"></i>Delete Bill
            </button>
        }
        <button type="button" class="btn btn-outline-primary btn-sm" onclick="window.print()">
            <i class="fa-solid fa-print me-1"></i>Print
        </button>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card p-3 h-100">
            <div class="text-muted small">Status</div>
            <div class="fw-semibold">
                @{
                    var statusClass = Model.Status switch
                    {
                        BillStatus.Approved => "text-success",
                        BillStatus.Cancelled => "text-danger",
                        _ => "text-secondary"
                    };
                }
                <span class="@statusClass">@Model.Status</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 h-100">
            <div class="text-muted small">Bill Date</div>
            <div class="fw-semibold">@Model.BillDate.ToString("dd/MM/yyyy")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 h-100">
            <div class="text-muted small">Supplier Ref</div>
            <div class="fw-semibold">@(Model.RefNo ?? "—")</div>
        </div>
    </div>
    @if (Model.WarehouseId.HasValue)
    {
        <div class="col-md-3">
            <div class="card p-3 h-100">
                <div class="text-muted small">Warehouse</div>
                <div class="fw-semibold">@(Model.WarehouseCode) — @(Model.WarehouseName)</div>
            </div>
        </div>
    }
    <div class="col-md-3">
        <div class="card p-3 h-100">
            <div class="text-muted small">Journal Entry</div>
            <div class="fw-semibold">@(Model.JournalEntryNumber ?? "—")</div>
        </div>
    </div>
</div>

<div class="card p-3">
    <h6 class="text-primary mb-3">Line Items</h6>
    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>Item / Description</th>
                    <th>Stack No</th>
                    <th>Lot No</th>
                    <th class="text-end">Cartons</th>
                    <th class="text-end">Qty</th>
                    <th class="text-end">Rate</th>
                    <th class="text-end">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(line.ItemCode))
                            {
                                <div><code>@line.ItemCode</code> @line.ItemName</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(line.Description))
                            {
                                <div class="text-muted small">@line.Description</div>
                            }
                        </td>
                        <td>@(line.StackNo ?? "—")</td>
                        <td>@(line.LotNo ?? "—")</td>
                        <td class="text-end">@line.Cartons.ToString("N2")</td>
                        <td class="text-end">@line.Quantity.ToString("N2")</td>
                        <td class="text-end text-currency">@line.Rate.ToString("N2")</td>
                        <td class="text-end text-currency fw-semibold">@line.Amount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="6" class="text-end">Subtotal</td>
                    <td class="text-end text-currency">@Model.SubTotal.ToString("N2")</td>
                </tr>
                <tr>
                    <td colspan="6" class="text-end">Sales Tax</td>
                    <td class="text-end text-currency">@Model.TaxAmount.ToString("N2")</td>
                </tr>
                @if (Model.WithholdingTaxAmount > 0 || Model.WithholdingTaxRate > 0)
                {
                    <tr>
                        <td colspan="6" class="text-end">W/H Tax u/s 153(1)(a) @@ @Model.WithholdingTaxRate.ToString("0.##")%</td>
                        <td class="text-end text-currency">@Model.WithholdingTaxAmount.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td colspan="6" class="text-end text-muted small">Nature of payment (GL 12810)</td>
                        <td class="text-end small text-muted">Withheld income tax adjustable</td>
                    </tr>
                }
                @if (Model.IncomeTax236GAmount > 0 || Model.IncomeTax236GRate > 0)
                {
                    <tr>
                        <td colspan="6" class="text-end">Income Tax u/s 236G @@ @Model.IncomeTax236GRate.ToString("0.##")%</td>
                        <td class="text-end text-currency">@Model.IncomeTax236GAmount.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td colspan="6" class="text-end text-muted small">GL 12820</td>
                        <td class="text-end small text-muted">—</td>
                    </tr>
                }
                <tr class="fw-bold">
                    <td colspan="6" class="text-end">Payable to Vendor</td>
                    <td class="text-end text-currency">@Model.NetAmount.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="card p-3 mb-3 no-print" id="bill-attachments-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h6 class="text-primary mb-0">Supporting Documents</h6>
            <p class="text-muted small mb-0">JPG, PNG, and PDF attachments</p>
        </div>
        @if (canEdit && Model.Status == BillStatus.Draft)
        {
            <label class="btn btn-outline-primary btn-sm mb-0" for="bill-attachment-upload">
                <i class="fa-solid fa-paperclip me-1"></i>Add Attachment
            </label>
            <input type="file" class="d-none" id="bill-attachment-upload" accept=".jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf" multiple />
        }
    </div>
    <div id="bill-attachments-list">
        @if (Model.Attachments.Count == 0)
        {
            <p class="text-muted small mb-0">No attachments uploaded.</p>
        }
        else
        {
            <div class="list-group list-group-flush">
                @foreach (var attachment in Model.Attachments)
                {
                    <div class="list-group-item d-flex flex-wrap justify-content-between align-items-center gap-2 px-0 attachment-row" data-id="@attachment.Id">
                        <div>
                            <a href="/api/vendor-bills/attachments/@attachment.Id/download" class="fw-semibold text-decoration-none" target="_blank" rel="noopener">
                                <i class="fa-solid fa-file me-1"></i>@attachment.FileName
                            </a>
                            <div class="text-muted small">@((attachment.FileSizeBytes / 1024.0).ToString("N1")) KB · @attachment.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        @if (canEdit && Model.Status == BillStatus.Draft)
                        {
                            <button type="button" class="btn btn-link btn-sm text-danger p-0 btn-delete-attachment" data-id="@attachment.Id">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/vendor-bill-details.js" asp-append-version="true"></script>
}
