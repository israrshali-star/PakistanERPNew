@using PakistanAccountingERP.Application.Interfaces
@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@inject ICurrentUserService CurrentUser
@{
    ViewData["Title"] = "Company & FBR Settings";
    var canCreate = await PermissionService.HasPermissionAsync("Settings.Create");
    var canEdit = await PermissionService.HasPermissionAsync("Settings.Edit");
    var canDelete = await PermissionService.HasPermissionAsync("Settings.Delete");
    var isSuperAdmin = CurrentUser.Roles.Any(r => string.Equals(r, "SuperAdmin", StringComparison.OrdinalIgnoreCase));
}

<div id="settings-permissions" class="d-none"
     data-can-create="@canCreate.ToString().ToLower()"
     data-can-edit="@canEdit.ToString().ToLower()"
     data-can-delete="@canDelete.ToString().ToLower()"
     data-is-super-admin="@isSuperAdmin.ToString().ToLower()"></div>
<div id="settings-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Company & FBR Settings</h4>
        <p class="text-muted small mb-0">Manage companies, profile, FBR e-invoicing, email/WhatsApp messaging, and default tax rates</p>
    </div>
    <div id="fbr-status-badge"></div>
</div>

<div class="card p-3 mb-3" id="companies-section">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h6 class="text-primary mb-0"><i class="fa-solid fa-building me-1"></i>Companies</h6>
        <button type="button" class="btn btn-primary btn-sm" id="btn-add-company" permission="Settings.Create">
            <i class="fa-solid fa-plus me-1"></i>Add Company
        </button>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0" id="companies-table">
            <thead>
                <tr>
                    <th>Company</th>
                    <th>NTN</th>
                    <th>Province</th>
                    <th>Contact</th>
                    <th class="text-center">Default</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="companies-table-body">
                <tr><td colspan="6" class="text-muted text-center">Loading companies…</td></tr>
            </tbody>
        </table>
    </div>
</div>

<form id="company-settings-form">
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card p-3 h-100">
                <h6 class="text-primary mb-3"><i class="fa-solid fa-building me-1"></i>Company Profile</h6>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="company-name">Company Name</label>
                        <input type="text" class="form-control" id="company-name" required maxlength="450" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="company-ntn">NTN (Seller)</label>
                        <input type="text" class="form-control" id="company-ntn" maxlength="50" placeholder="Used on FBR submissions" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="province-id">Province</label>
                        <select class="form-select" id="province-id">
                            <option value="">— Select —</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="company-address">Address</label>
                        <textarea class="form-control" id="company-address" rows="2" maxlength="500"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="company-phone">Phone</label>
                        <input type="text" class="form-control" id="company-phone" maxlength="50" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="company-email">Email</label>
                        <input type="email" class="form-control" id="company-email" maxlength="200" />
                    </div>
                    <div class="col-md-6" id="godown-email-group">
                        <label class="form-label" for="godown-email">Godown Email</label>
                        <input type="email" class="form-control" id="godown-email" maxlength="200" placeholder="Delivery challan dispatch address" />
                        <div class="form-text">Delivery challan PDFs are emailed here from sales invoices (company 3 only).</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card p-3 h-100">
                <h6 class="text-primary mb-3"><i class="fa-solid fa-paper-plane me-1"></i>FBR E-Invoicing</h6>
                <div class="alert alert-info small" id="fbr-mode-hint">
                    Loading FBR configuration status...
                </div>
                <div class="mb-3">
                    <label class="form-label" for="fbr-post-url">FBR Post URL</label>
                    <input type="url" class="form-control" id="fbr-post-url" placeholder="https://gw.fbr.gov.pk/..." />
                    <div class="form-text">Leave blank to use simulation mode on invoice submission.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="api-token">API Token</label>
                    <input type="password" class="form-control" id="api-token" placeholder="Enter new token to update" autocomplete="new-password" />
                    <div class="form-text" id="api-token-hint"></div>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="clear-api-token" />
                    <label class="form-check-label" for="clear-api-token">Clear stored API token</label>
                </div>
            </div>
        </div>

        <div class="col-12" id="tax-section">
            <div class="card p-3">
                <h6 class="text-primary mb-3"><i class="fa-solid fa-percent me-1"></i>Tax Settings</h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label" for="tax-group-name">Tax Group</label>
                        <input type="text" class="form-control" id="tax-group-name" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="sales-tax-rate">Registered Sales Tax %</label>
                        <input type="number" class="form-control" id="sales-tax-rate" step="0.01" min="0" max="100" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="unreg-tax-rate">Unregistered Sales Tax %</label>
                        <input type="number" class="form-control" id="unreg-tax-rate" step="0.01" min="0" max="100" required />
                    </div>
                </div>
                <p class="text-muted small mb-0 mt-2">Default rates used when creating sales invoices and items.</p>
            </div>
        </div>

        <div class="col-lg-6 d-none" id="email-settings-section">
            <div class="card p-3 h-100">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h6 class="text-primary mb-0"><i class="fa-solid fa-envelope me-1"></i>Email Settings (SMTP)</h6>
                    <span id="smtp-status-badge"></span>
                </div>
                <p class="text-muted small">Configure outbound email for invoice sharing, ledgers, and delivery challans. SuperAdmin only.</p>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="smtp-enabled" />
                    <label class="form-check-label" for="smtp-enabled">Enable email sending</label>
                </div>
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label" for="smtp-host">SMTP Host</label>
                        <input type="text" class="form-control" id="smtp-host" maxlength="200" placeholder="smtp.gmail.com" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="smtp-port">Port</label>
                        <input type="number" class="form-control" id="smtp-port" min="1" max="65535" value="587" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="smtp-username">Username</label>
                        <input type="text" class="form-control" id="smtp-username" maxlength="200" autocomplete="off" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="smtp-password">Password / App Password</label>
                        <input type="password" class="form-control" id="smtp-password" placeholder="Enter new password to update" autocomplete="new-password" />
                        <div class="form-text" id="smtp-password-hint"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="smtp-from-email">From Email</label>
                        <input type="email" class="form-control" id="smtp-from-email" maxlength="200" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="smtp-from-name">From Name</label>
                        <input type="text" class="form-control" id="smtp-from-name" maxlength="200" placeholder="Pakistan Accounting ERP" />
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="smtp-use-ssl" checked />
                            <label class="form-check-label" for="smtp-use-ssl">Use SSL / STARTTLS (recommended for port 587)</label>
                        </div>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="clear-smtp-password" />
                            <label class="form-check-label" for="clear-smtp-password">Clear stored SMTP password</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 d-none" id="whatsapp-settings-section">
            <div class="card p-3 h-100">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h6 class="text-primary mb-0"><i class="fa-brands fa-whatsapp me-1"></i>WhatsApp Settings</h6>
                    <span id="whatsapp-status-badge"></span>
                </div>
                <p class="text-muted small">WhatsApp Business Cloud API credentials for server-side messaging. Manual share via WhatsApp Web still works without this. SuperAdmin only.</p>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="whatsapp-enabled" />
                    <label class="form-check-label" for="whatsapp-enabled">Enable WhatsApp Business API</label>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="whatsapp-api-url">API Base URL</label>
                        <input type="url" class="form-control" id="whatsapp-api-url" maxlength="500" placeholder="https://graph.facebook.com/v21.0/" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="whatsapp-phone-number-id">Phone Number ID</label>
                        <input type="text" class="form-control" id="whatsapp-phone-number-id" maxlength="100" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="whatsapp-access-token">Access Token</label>
                        <input type="password" class="form-control" id="whatsapp-access-token" placeholder="Enter new token to update" autocomplete="new-password" />
                        <div class="form-text" id="whatsapp-token-hint"></div>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="clear-whatsapp-token" />
                            <label class="form-check-label" for="clear-whatsapp-token">Clear stored access token</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-danger d-none mt-3" id="settings-form-error"></div>
    <div class="alert alert-success d-none mt-3" id="settings-form-success"></div>

    <div class="mt-3" permission="Settings.Edit">
        <button type="submit" class="btn btn-primary" id="btn-save-settings">
            <i class="fa-solid fa-floppy-disk me-1"></i>Save Settings
        </button>
    </div>
</form>

<div class="modal fade" id="companyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="companyModalLabel">Company</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="company-form">
                <div class="modal-body">
                    <input type="hidden" id="manage-company-id" />
                    <div class="mb-3">
                        <label class="form-label" for="manage-company-name">Company Name</label>
                        <input type="text" class="form-control" id="manage-company-name" required maxlength="450" />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="manage-company-ntn">NTN</label>
                            <input type="text" class="form-control" id="manage-company-ntn" maxlength="50" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="manage-province-id">Province</label>
                            <select class="form-select" id="manage-province-id">
                                <option value="">— Select —</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="manage-company-address">Address</label>
                            <textarea class="form-control" id="manage-company-address" rows="2" maxlength="500"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="manage-company-phone">Phone</label>
                            <input type="text" class="form-control" id="manage-company-phone" maxlength="50" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="manage-company-email">Email</label>
                            <input type="email" class="form-control" id="manage-company-email" maxlength="200" />
                        </div>
                    </div>
                    <div class="form-check mt-3">
                        <input class="form-check-input" type="checkbox" id="manage-company-default" />
                        <label class="form-check-label" for="manage-company-default">Set as default company (used on login)</label>
                    </div>
                    <div class="alert alert-danger d-none mt-3" id="company-form-error"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="btn-save-company">Save Company</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/company-settings.js" asp-append-version="true"></script>
}
