@model List<PakistanAccountingERP.Web.Models.NavMenuItem>
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<ul class="top-nav-list nav">
    @foreach (var item in Model)
    {
        if (item.IsGroup)
        {
            var groupId = $"nav-{item.Title.Replace(" ", "").ToLower()}";
            var groupActive = item.Children.Any(c =>
                !string.IsNullOrEmpty(c.Controller)
                && string.Equals(c.Controller, controller, StringComparison.OrdinalIgnoreCase)
                && string.Equals(c.Action ?? "Index", action, StringComparison.OrdinalIgnoreCase));
            <li class="nav-item top-nav-group @(groupActive ? "active" : "")">
                <a class="nav-link top-nav-group-label d-none d-xl-inline-flex" href="#" tabindex="0" aria-haspopup="true">
                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <i class="fa-solid @item.Icon top-nav-icon"></i>
                    }
                    <span>@item.Title</span>
                    <i class="fa-solid fa-chevron-down top-nav-chevron ms-1"></i>
                </a>
                <a class="nav-link top-nav-group-toggle d-xl-none @(groupActive ? "" : "collapsed")"
                   data-bs-toggle="collapse"
                   href="#@groupId"
                   role="button"
                   aria-expanded="@groupActive.ToString().ToLower()"
                   aria-controls="@groupId">
                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <i class="fa-solid @item.Icon top-nav-icon"></i>
                    }
                    <span>@item.Title</span>
                    <i class="fa-solid fa-chevron-down top-nav-chevron ms-auto"></i>
                </a>
                <div class="top-nav-submenu collapse @(groupActive ? "show" : "")" id="@groupId">
                    <ul class="list-unstyled mb-0">
                        @foreach (var child in item.Children)
                        {
                            var childActive = !string.IsNullOrEmpty(child.Controller)
                                && string.Equals(child.Controller, controller, StringComparison.OrdinalIgnoreCase)
                                && string.Equals(child.Action ?? "Index", action, StringComparison.OrdinalIgnoreCase);
                            <li>
                                @if (!string.IsNullOrEmpty(child.Controller))
                                {
                                    <a class="top-nav-sublink @(childActive ? "active" : "")"
                                       asp-controller="@child.Controller"
                                       asp-action="@(child.Action ?? "Index")">@child.Title</a>
                                }
                                else
                                {
                                    <a class="top-nav-sublink" href="@(child.Url ?? "#")">@child.Title</a>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </li>
        }
        else
        {
            var isActive = string.Equals(item.Controller, controller, StringComparison.OrdinalIgnoreCase)
                && string.Equals(item.Action, action, StringComparison.OrdinalIgnoreCase);
            <li class="nav-item">
                <a class="nav-link @(isActive ? "active" : "")"
                   asp-controller="@item.Controller" asp-action="@item.Action">
                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <i class="fa-solid @item.Icon top-nav-icon"></i>
                    }
                    <span>@item.Title</span>
                </a>
            </li>
        }
    }
</ul>
