@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var appName = Configuration["AppSettings:ApplicationName"] ?? "Pakistan Accounting ERP";
    var version = Configuration["AppSettings:Version"] ?? "1.0.0";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @appName</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PakistanAccountingERP.Web.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="app-body">
    <header class="app-header top-navbar">
        <div class="app-header-top">
            <div class="d-flex align-items-center gap-2">
                <a asp-controller="Home" asp-action="Index" class="app-brand">
                    <i class="fa-solid fa-calculator"></i>
                    <span id="app-brand-name">PA ERP</span>
                </a>
                <button type="button" class="btn btn-link nav-toggle d-xl-none" id="navToggle" aria-label="Toggle navigation">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>

            <div class="app-header-actions d-flex align-items-center gap-2 gap-md-3">
                <span id="header-company-name" class="header-company-name" title="PA ERP">
                    <i class="fa-solid fa-building me-1"></i>
                    <span id="current-company-name">Loading...</span>
                </span>

                <button type="button" class="btn btn-link top-navbar-icon text-white-50" title="Notifications">
                    <i class="fa-regular fa-bell"></i>
                </button>

                <div class="dropdown user-menu">
                    <button class="btn btn-link dropdown-toggle user-menu-btn text-white" type="button" data-bs-toggle="dropdown">
                        <span class="user-avatar user-avatar-light">
                            <i class="fa-solid fa-user"></i>
                        </span>
                        <span class="d-none d-md-inline ms-1">@(User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User")</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><h6 class="dropdown-header">@(User.Identity?.Name)</h6></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                                <i class="fa-solid fa-key me-2"></i>Change Password
                            </button>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="px-3 py-1">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fa-solid fa-right-from-bracket me-2"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <nav id="topNav" class="top-nav sidebar">
            @await Component.InvokeAsync("Sidebar")
        </nav>

        <div class="nav-overlay d-xl-none" id="navOverlay"></div>
    </header>

    <div class="main-wrapper">
        <div class="content-header">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                @await Html.PartialAsync("_Breadcrumb")
                <h1 class="page-title d-none d-md-block mb-0">@ViewData["Title"]</h1>
            </div>
        </div>

        <main class="content-area container-fluid" role="main">
            @RenderBody()
        </main>

        <footer class="app-footer">
            <span>&copy; @DateTime.Now.Year @appName</span>
            <span class="text-muted">v@version | Currency: PKR</span>
        </footer>
    </div>

    @await Html.PartialAsync("_ChangePasswordModal")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/change-password.js" asp-append-version="true"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
