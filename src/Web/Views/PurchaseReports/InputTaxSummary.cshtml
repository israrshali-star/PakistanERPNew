@{
    ViewData["Title"] = "Input Tax Summary";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-1">Input Tax Summary</h4>
        <p class="text-muted small mb-0">Recoverable input tax from approved purchase bills</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-print-report">
            <i class="fa-solid fa-print me-1"></i>Print / Save PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3 no-print"></div>

<div class="card p-3 mb-3 no-print">
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label" for="filter-from">From Date</label>
            <input type="date" class="form-control" id="filter-from" />
        </div>
        <div class="col-md-2">
            <label class="form-label" for="filter-to">To Date</label>
            <input type="date" class="form-control" id="filter-to" />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="filter-vendor">Vendor</label>
            <select class="form-select select2" id="filter-vendor">
                <option value="">All vendors</option>
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="filter-approved-only" checked />
                <label class="form-check-label" for="filter-approved-only">Approved only</label>
            </div>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-primary w-100" id="btn-load-report">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Load
            </button>
        </div>
    </div>
</div>

<div class="card p-3 report-print-area report-print-fit" id="report-content">
    <div class="text-center mb-4">
        <h5 class="text-primary mb-1">Input Tax Summary</h5>
        <p class="text-muted small mb-0" id="report-period">Select dates and click Load</p>
    </div>

    <div class="row g-3 justify-content-center">
        <div class="col-md-8">
            <table class="table table-bordered mb-0">
                <tbody id="report-summary">
                    <tr><td colspan="2" class="text-muted text-center">No data loaded.</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/report-print.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/modules/report-print-common.js" asp-append-version="true"></script>
    <script src="~/js/modules/purchase-report-input-tax.js" asp-append-version="true"></script>
}
