@{
    ViewData["Title"] = "Stack & Lot Tracking";
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3 no-print">
    <div>
        <h4 class="text-primary mb-1">Stack &amp; Lot Tracking</h4>
        <p class="text-muted small mb-0">Purchased vs sold cartons and weight by item, lot, and stack</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-print-report">
            <i class="fa-solid fa-print me-1"></i>Print / Save PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div id="report-company-warning" class="alert alert-warning d-none mb-3 no-print"></div>

<div class="card p-3 mb-3 no-print">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label" for="filter-item">Item</label>
            <select class="form-select select2" id="filter-item">
                <option value="">All items</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label" for="filter-lot">Lot No</label>
            <select class="form-select" id="filter-lot">
                <option value="">All lots</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label" for="filter-stack">Stack No</label>
            <select class="form-select" id="filter-stack">
                <option value="">All stacks</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-primary w-100" id="btn-load-report">
                <i class="fa-solid fa-magnifying-glass me-1"></i>Load
            </button>
        </div>
    </div>
</div>

<div class="card p-3 report-print-area report-print-landscape" id="report-content">
    <div class="text-center mb-4">
        <h5 class="text-primary mb-1">Stack &amp; Lot Tracking Report</h5>
        <p class="text-muted small mb-0" id="report-filter-label">Select filters and click Load</p>
    </div>

    <div class="table-responsive mb-4">
        <table class="table table-sm table-bordered mb-0">
            <thead class="table-light">
                <tr>
                    <th>Item</th>
                    <th>Stack No</th>
                    <th>Lot No</th>
                    <th class="text-end">Purchased Cartons</th>
                    <th class="text-end">Purchased Weight</th>
                    <th class="text-end">Purchase Amount</th>
                    <th class="text-end">Sold Cartons</th>
                    <th class="text-end">Sold Weight</th>
                    <th class="text-end">Sold Amount</th>
                    <th class="text-end">Remaining Cartons</th>
                    <th class="text-end">Remaining Weight</th>
                </tr>
            </thead>
            <tbody id="report-lines">
                <tr><td colspan="11" class="text-muted text-center">No data loaded.</td></tr>
            </tbody>
            <tfoot id="report-footer" class="d-none table-light">
                <tr>
                    <th colspan="3" class="text-end">Totals</th>
                    <th class="text-end" id="report-total-purchased-cartons">0.00</th>
                    <th class="text-end" id="report-total-purchased-weight">0.00</th>
                    <th class="text-end" id="report-total-purchased-amount">0.00</th>
                    <th class="text-end" id="report-total-sold-cartons">0.00</th>
                    <th class="text-end" id="report-total-sold-weight">0.00</th>
                    <th class="text-end" id="report-total-sold-amount">0.00</th>
                    <th class="text-end" id="report-total-remaining-cartons">0.00</th>
                    <th class="text-end" id="report-total-remaining-weight">0.00</th>
                </tr>
            </tfoot>
        </table>
    </div>

    <div id="report-movements-section" class="d-none">
        <h6 class="text-primary mb-3">Movement Detail</h6>
        <div id="report-movements"></div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/report-print.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/modules/report-print-common.js" asp-append-version="true"></script>
    <script src="~/js/modules/purchase-report-stack-lot.js" asp-append-version="true"></script>
}
