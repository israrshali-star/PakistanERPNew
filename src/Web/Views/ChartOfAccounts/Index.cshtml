@using PakistanAccountingERP.Application.Interfaces
@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@inject ICurrentUserService CurrentUser
@{
    ViewData["Title"] = "Chart of Accounts";
    var canCreate = await PermissionService.HasPermissionAsync("ChartOfAccounts.Create");
    var canEdit = await PermissionService.HasPermissionAsync("ChartOfAccounts.Edit");
    var canDelete = await PermissionService.HasPermissionAsync("ChartOfAccounts.Delete");
    var isSuperAdmin = CurrentUser.Roles.Any(r => string.Equals(r, "SuperAdmin", StringComparison.OrdinalIgnoreCase));
}

<div id="coa-permissions" class="d-none"
     data-can-create="@canCreate.ToString().ToLower()"
     data-can-edit="@canEdit.ToString().ToLower()"
     data-can-delete="@canDelete.ToString().ToLower()"
     data-is-super-admin="@isSuperAdmin.ToString().ToLower()"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">

    <div>

        <h4 class="text-primary mb-0">Chart of Accounts</h4>

        <p class="text-muted small mb-0">
            All main accounts can have child accounts; group totals roll up opening and closing balances
            <span id="coa-total-count" class="badge bg-primary ms-1 d-none"></span>
        </p>

    </div>

    <div class="d-flex gap-2">

        <button type="button" class="btn btn-outline-primary btn-sm" id="btn-export-coa">

            <i class="fa-solid fa-file-excel me-1"></i>Export Excel

        </button>

        <button type="button" class="btn btn-primary btn-sm" id="btn-add-account" permission="ChartOfAccounts.Create">

            <i class="fa-solid fa-plus me-1"></i>New Account

        </button>

    </div>

</div>



<div id="coa-notice" class="d-none alert alert-warning mb-3"></div>

<div id="coa-tree-container">

    <div class="text-center text-muted py-5">

        <i class="fa-solid fa-spinner fa-spin me-2"></i>Loading chart of accounts...

    </div>

</div>



<div class="modal fade" id="accountModal" tabindex="-1" aria-labelledby="accountModalLabel" aria-hidden="true">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title text-primary" id="accountModalLabel">Account</h5>

                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>

            </div>

            <form id="account-form">

                <div class="modal-body">

                    <input type="hidden" id="account-id" />

                    <div class="row g-3">

                        <div class="col-md-4">

                            <label class="form-label" for="account-type">Account Type</label>

                            <select class="form-select" id="account-type" required></select>

                        </div>

                        <div class="col-md-4">

                            <label class="form-label" for="account-subtype">Sub Type</label>

                            <select class="form-select" id="account-subtype" required disabled>

                                <option value="">Select account type first...</option>

                            </select>

                        </div>

                        <div class="col-md-4">

                            <label class="form-label" for="account-number">Account Number</label>

                            <div class="input-group">

                                <input type="text" class="form-control" id="account-number" required maxlength="20" />

                                <button type="button" class="btn btn-outline-secondary" id="btn-suggest-number" title="Suggest number">

                                    <i class="fa-solid fa-wand-magic-sparkles"></i>

                                </button>

                            </div>

                        </div>

                        <div class="col-md-4">

                            <label class="form-label" for="account-parent">Parent Account</label>

                            <select class="form-select" id="account-parent">

                                <option value="">None — Main / Header account</option>

                            </select>

                            <div class="form-text">Works for every account type. Child accounts hold balances; main groups show the sum of children.</div>

                        </div>

                        <div class="col-md-8">

                            <label class="form-label" for="account-name">Account Name</label>

                            <input type="text" class="form-control" id="account-name" required maxlength="200" />

                        </div>

                        <div class="col-md-4">

                            <label class="form-label" for="opening-balance">Opening Balance (PKR)</label>

                            <input type="number" class="form-control" id="opening-balance" step="0.01" value="0" />

                            <div class="form-text d-none" id="opening-balance-hint">Group accounts show the total of all child balances.</div>

                        </div>

                        <div class="col-12">

                            <label class="form-label" for="account-description">Description</label>

                            <textarea class="form-control" id="account-description" rows="2" maxlength="500"></textarea>

                        </div>

                        <div class="col-12">

                            <div class="form-check">

                                <input class="form-check-input" type="checkbox" id="account-active" checked />

                                <label class="form-check-label" for="account-active">Active</label>

                            </div>

                        </div>

                    </div>

                    <div class="alert alert-danger d-none mt-3" id="account-form-error"></div>

                </div>

                <div class="modal-footer">

                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>

                    <button type="submit" class="btn btn-primary" id="btn-save-account">Save</button>

                </div>

            </form>

        </div>

    </div>

</div>



<div class="modal fade" id="accountLedgerModal" tabindex="-1" aria-labelledby="accountLedgerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title text-primary" id="accountLedgerModalLabel">Account Ledger</h5>
                    <p class="text-muted small mb-0" id="account-ledger-subtitle"></p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label" for="account-ledger-from">From Date</label>
                        <input type="date" class="form-control" id="account-ledger-from" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="account-ledger-to">To Date</label>
                        <input type="date" class="form-control" id="account-ledger-to" />
                    </div>
                    <div class="col-md-3">
                        <button type="button" class="btn btn-primary w-100" id="btn-apply-ledger-filter">
                            <i class="fa-solid fa-filter me-1"></i>Apply
                        </button>
                    </div>
                    <div class="col-md-3">
                        <button type="button" class="btn btn-outline-secondary w-100" id="btn-clear-ledger-filter">Clear</button>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <div class="card card-kpi p-3">
                            <div class="kpi-label">Opening Balance</div>
                            <div class="kpi-value text-currency" id="account-ledger-opening">0.00</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card card-kpi p-3">
                            <div class="kpi-label">Period Debits</div>
                            <div class="kpi-value text-currency" id="account-ledger-period-debit">0.00</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card card-kpi p-3">
                            <div class="kpi-label">Period Credits</div>
                            <div class="kpi-value text-currency" id="account-ledger-period-credit">0.00</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card card-kpi p-3">
                            <div class="kpi-label">Closing Balance</div>
                            <div class="kpi-value text-currency" id="account-ledger-closing">0.00</div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Reference</th>
                                <th>Description</th>
                                <th class="text-end">Debit</th>
                                <th class="text-end">Credit</th>
                                <th class="text-end">Balance</th>
                            </tr>
                        </thead>
                        <tbody id="account-ledger-body">
                            <tr><td colspan="6" class="text-muted text-center">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger" id="btn-ledger-export-pdf">
                    <i class="fa-solid fa-file-pdf me-1"></i>Save PDF
                </button>
                <button type="button" class="btn btn-outline-success" id="btn-ledger-export-excel">
                    <i class="fa-solid fa-file-excel me-1"></i>Export Excel
                </button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script src="~/js/modules/chart-of-accounts.js" asp-append-version="true"></script>

}

