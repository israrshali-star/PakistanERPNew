@using PakistanAccountingERP.Application.DTOs

@using PakistanAccountingERP.Application.Interfaces

@using PakistanAccountingERP.Application.Interfaces.Services

@using PakistanAccountingERP.Domain.Enums

@inject ICurrentUserService CurrentUser

@inject IPermissionService PermissionService

@model JournalEntryDetailDto

@{

    ViewData["Title"] = "Edit " + Model.EntryNumber;

    var isSuperAdmin = CurrentUser.Roles.Any(r => string.Equals(r, "SuperAdmin", StringComparison.OrdinalIgnoreCase));

    var isPosted = Model.Status == JournalStatus.Posted;

    var canDelete = await PermissionService.HasPermissionAsync("JournalEntries.Delete");

    var canDeleteEntry = canDelete && Model.CanDelete;

}



<div id="journal-entry-edit"

     data-entry-id="@Model.Id"

     data-status="@Model.Status"

     data-can-delete="@canDeleteEntry.ToString().ToLower()"

     data-is-super-admin="@isSuperAdmin.ToString().ToLower()"

     data-is-posted="@isPosted.ToString().ToLower()"></div>



<div id="je-company-warning" class="alert alert-warning d-none mb-3"></div>



@if (isSuperAdmin && isPosted)

{

    <div class="alert alert-info mb-3">

        <i class="fa-solid fa-shield-halved me-1"></i>

        SuperAdmin: you are editing a posted journal entry. Changes apply directly to the general ledger.

    </div>

}

@if (isPosted && !Model.IsManualEntry && !isSuperAdmin)

{

    <div class="alert alert-warning mb-3">

        <i class="fa-solid fa-circle-info me-1"></i>

        This entry is linked to <strong>@Model.SourceLabel</strong>. Prefer <strong>Repost from Source</strong> on the details page after fixing the receipt or payment.

    </div>

}



<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">

    <div>

        <h4 class="text-primary mb-0">Edit @Model.EntryNumber</h4>

        <p class="text-muted small mb-0">@Model.SourceLabel · @Model.Status</p>

    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to details
        </a>
        @if (canDeleteEntry)
        {
            <button type="button" class="btn btn-outline-danger btn-sm" id="btn-delete-entry">
                <i class="fa-solid fa-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>



<form id="journal-entry-form">

    <div class="card p-3 mb-3">

        <h6 class="text-primary mb-3">Entry Header</h6>

        <div class="row g-3">

            <div class="col-md-3">

                <label class="form-label" for="entry-number">Entry Number</label>

                <input type="text" class="form-control" id="entry-number" readonly value="@Model.EntryNumber" />

            </div>

            <div class="col-md-3">

                <label class="form-label" for="entry-date">Entry Date</label>

                <input type="date" class="form-control" id="entry-date" required value="@Model.EntryDate.ToString("yyyy-MM-dd")" />

            </div>

            <div class="col-md-6">

                <label class="form-label" for="entry-description">Description</label>

                <input type="text" class="form-control" id="entry-description" maxlength="500" placeholder="Optional narration" value="@Model.Description" />

            </div>

        </div>

    </div>



    <div class="card p-3 mb-3">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h6 class="text-primary mb-0">Journal Lines</h6>

            <button type="button" class="btn btn-outline-primary btn-sm" id="btn-add-line">

                <i class="fa-solid fa-plus me-1"></i>Add Line

            </button>

        </div>

        <div class="table-responsive">

            <table class="table table-sm align-middle mb-0">

                <thead>

                    <tr>

                        <th style="min-width:220px">Account</th>

                        <th class="text-end" style="width:120px">Debit</th>

                        <th class="text-end" style="width:120px">Credit</th>

                        <th style="min-width:160px">Memo</th>

                        <th style="width:40px"></th>

                    </tr>

                </thead>

                <tbody id="je-lines-body"

                       data-lines='@System.Text.Json.JsonSerializer.Serialize(Model.Lines.Select(l => new { accountId = l.ChartOfAccountId, debit = l.Debit, credit = l.Credit, memo = l.Memo }))'></tbody>

                <tfoot>

                    <tr class="table-light">

                        <th class="text-end">Totals</th>

                        <th class="text-end text-currency" id="total-debit">@Model.TotalDebit.ToString("N2")</th>

                        <th class="text-end text-currency" id="total-credit">@Model.TotalCredit.ToString("N2")</th>

                        <th colspan="2">

                            <span id="balance-status" class="badge bg-success">Balanced</span>

                        </th>

                    </tr>

                </tfoot>

            </table>

        </div>

    </div>



    <div class="alert alert-danger d-none" id="je-form-error"></div>



    <div class="d-flex gap-2">

        <button type="submit" class="btn btn-primary">

            <i class="fa-solid fa-floppy-disk me-1"></i>Save Changes

        </button>

        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>

    </div>

</form>



@section Scripts {

    <script src="~/js/modules/journal-entry-create.js" asp-append-version="true"></script>

    <script src="~/js/modules/journal-entry-details.js" asp-append-version="true"></script>

}


