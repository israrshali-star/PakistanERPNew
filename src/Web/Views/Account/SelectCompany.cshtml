@model PakistanAccountingERP.Web.ViewModels.SelectCompanyViewModel
@{
    ViewData["Title"] = "Select Company";
    Layout = "_LoginLayout";
}

<div class="auth-card">
    <div class="auth-header text-center mb-4">
        <h1 class="auth-title">Select Company</h1>
        <p class="text-muted mb-0">Choose which company account to work in for this session</p>
    </div>

    @if (Model.Companies.Count == 0)
    {
        <div class="alert alert-warning">
            No companies are assigned to your user account. Contact an administrator.
        </div>
        <form asp-action="Logout" asp-controller="Account" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary w-100">Sign Out</button>
        </form>
    }
    else
    {
        <form asp-action="SelectCompany" asp-controller="Account" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="CompanyId" class="form-label"></label>
                <select asp-for="CompanyId" class="form-select" required>
                    <option value="">— Select company —</option>
                    @foreach (var company in Model.Companies)
                    {
                        <option value="@company.Id">
                            @company.CompanyName@(company.IsDefault ? " (Default)" : "")
                        </option>
                    }
                </select>
                <span asp-validation-for="CompanyId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Continue</button>
        </form>

        <form asp-action="Logout" asp-controller="Account" method="post" class="mt-3">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-link w-100 text-muted">Sign out</button>
        </form>
    }
</div>
