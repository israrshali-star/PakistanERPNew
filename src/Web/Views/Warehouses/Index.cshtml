@using PakistanAccountingERP.Application.Interfaces.Services
@inject IPermissionService PermissionService
@{
    ViewData["Title"] = "Warehouses";
    var canCreate = await PermissionService.HasPermissionAsync("Inventory.Create");
    var canEdit = await PermissionService.HasPermissionAsync("Inventory.Edit");
    var canDelete = await PermissionService.HasPermissionAsync("Inventory.Delete");
}

<div id="warehouse-permissions" class="d-none"
     data-can-create="@canCreate.ToString().ToLower()"
     data-can-edit="@canEdit.ToString().ToLower()"
     data-can-delete="@canDelete.ToString().ToLower()"></div>

<div id="warehouse-company-warning" class="alert alert-warning d-none mb-3"></div>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h4 class="text-primary mb-0">Warehouses</h4>
        <p class="text-muted small mb-0">Storage locations for inventory stock movements</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm" id="btn-add-warehouse" permission="Inventory.Create">
        <i class="fa-solid fa-warehouse me-1"></i>New Warehouse
    </button>
</div>

<div class="card p-3">
    <div class="table-responsive">
        <table class="table table-hover w-100" id="warehouses-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Address</th>
                    <th>Status</th>
                    <th class="text-end">Transactions</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="warehouseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-primary" id="warehouseModalLabel">Warehouse</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="warehouse-form">
                <div class="modal-body">
                    <input type="hidden" id="warehouse-id" />
                    <div class="mb-3">
                        <label class="form-label" for="warehouse-code">Code</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="warehouse-code" required maxlength="50" />
                            <button type="button" class="btn btn-outline-secondary" id="btn-generate-warehouse-code" title="Generate code">
                                <i class="fa-solid fa-wand-magic-sparkles"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="warehouse-name">Name</label>
                        <input type="text" class="form-control" id="warehouse-name" required maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="warehouse-address">Address</label>
                        <textarea class="form-control" id="warehouse-address" rows="2" maxlength="500"></textarea>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="warehouse-active" checked />
                        <label class="form-check-label" for="warehouse-active">Active</label>
                    </div>
                    <div class="alert alert-danger d-none mt-3" id="warehouse-form-error"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/warehouses.js" asp-append-version="true"></script>
}
