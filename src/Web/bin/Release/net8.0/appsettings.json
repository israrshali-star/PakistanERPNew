{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=PakistanAccountingERP;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "SeedOnStartup": true
  },
  "AppSettings": {
    "ApplicationName": "Pakistan Accounting ERP",
    "Version": "1.0.0",
    "DefaultCurrency": "PKR",
    "DateFormat": "yyyy/MM/dd",
    "SessionTimeoutMinutes": 60
  },
  "Backup": {
    "Enabled": true,
    "IntervalHours": 24,
    "RetentionDays": 14,
    "StoragePath": "App_Data/Backups"
  },
  "Export": {
    "StoragePath": "App_Data/Exports"
  },
  "Attachments": {
    "StoragePath": "App_Data/Attachments",
    "MaxFileSizeMb": 10,
    "MaxFilesPerInvoice": 10,
    "MaxFilesPerBill": 10
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
